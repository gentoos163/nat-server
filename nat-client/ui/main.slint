    in property <string> account_new_password: "新密码";
    in property <string> account_change_password: "修改密码";
    in property <string> account_token_remaining: "Token 剩余：";
    in property <string> account_register_link: "注册账户 →";
    in property <string> account_login_link: "← 返回登录";
    in property <string> account_sub_plan: "我的套餐";
    in property <string> account_sub_current: "当前套餐";
    in property <string> account_sub_device_usage: "设备使用";
    in property <string> account_sub_expires: "到期时间";
    in property <string> account_sub_forever: "永久";

    in property <string> devices_title: "设备";
    in property <string> devices_id: "设备 ID";
    in property <string> devices_name: "名称";
    in property <string> devices_remove: "移除";
    in property <string> devices_no_devices: "暂无绑定设备";

    in property <string> settings_title: "设置";
    in property <string> settings_server: "服务器地址";
    in property <string> settings_relay: "中继服务器";
    in property <string> settings_peer_id: "设备 ID";
    in property <string> settings_protocol: "协议";
    in property <string> settings_language: "界面语言";
    in property <string> settings_open_config: "打开配置文件";
    in property <string> settings_save: "保存设置";
    in property <string> lang_zh: "中文";
    in property <string> lang_en: "English";
}

// ─────────────────────────────────────────────────────────────
// 数据结构
// ─────────────────────────────────────────────────────────────

export struct LanPeer {
    id: string,
    ip: string,
    hostname: string,
    username: string,
    platform: string,
    online: bool,
}

export struct ActiveConn {
    uuid: string,
    conn-type: string,
    peer-addr: string,
    local-port: int,
    bytes-sent: string,
    bytes-recv: string,
    created-at: string,
}

export struct BoundDevice {
    id: int,
    device-id: string,
    device-name: string,
    is-active: bool,
    is-online: bool,
    created-at: string,
}

export struct ForwardRule {
    rule-id: string,
    name: string,
    target-host: string,
    target-port: string,   // 字符串，便于直接拼接显示
    peer-id-filter: string,
}

// ─────────────────────────────────────────────────────────────
// 主题状态（由 Rust 初始化并在切换时更新）
// ─────────────────────────────────────────────────────────────

export global ThemeState {
    in-out property <bool> dark: true;
}

// ─────────────────────────────────────────────────────────────
// 调色板（所有颜色随 ThemeState.dark 自动切换）
// ─────────────────────────────────────────────────────────────

global Palette {
    // ── 主背景渐变端点 ────────────────────────────────────────
    out property <color> bg:            ThemeState.dark ? #070a13 : #f5f5f7;
    out property <color> bg2:           ThemeState.dark ? #0a0714 : #eeeef3;
    // ── 侧边栏渐变端点 ────────────────────────────────────────
    out property <color> sidebar-from:  ThemeState.dark ? #06080f : #f8f8fa;
    out property <color> sidebar-to:    ThemeState.dark ? #05060c : #ececf0;
    // ── 玻璃卡片渐变端点 ─────────────────────────────────────
    out property <color> card-from:     ThemeState.dark ? #ffffff11 : #ffffffef;
    out property <color> card-to:       ThemeState.dark ? #ffffff06 : #f5f5f7d9;
    // ── 玻璃边框 / 输入 / 通用面 ─────────────────────────────
    out property <color> border:        ThemeState.dark ? #ffffff20 : #0000001a;
    out property <color> border-hi:     ThemeState.dark ? #ffffff44 : #00000033;
    out property <color> surface:       ThemeState.dark ? #ffffff09 : #ffffffcc;
    out property <color> surface2:      ThemeState.dark ? #ffffff05 : #0000000a;
    out property <color> surface-focus: ThemeState.dark ? #ffffff11 : #ffffffee;
    // ── 侧边栏竖分割线端点 ────────────────────────────────────
    out property <color> divider-v-mid: ThemeState.dark ? #ffffff18 : #00000014;
    // ── 规则列表行底色 ────────────────────────────────────────
    out property <color> rule-bg:       ThemeState.dark ? #ffffff07 : #00000007;
    // ── 代码块 ───────────────────────────────────────────────
    out property <color> code-bg:       ThemeState.dark ? #00000088 : #0000001a;
    out property <color> code-text:     ThemeState.dark ? #86efac   : #166534;
    // ── 按钮禁用底色渐变端点 ─────────────────────────────────
    out property <color> btn-dis-from:  ThemeState.dark ? #ffffff0d : #0000000f;
    out property <color> btn-dis-to:    ThemeState.dark ? #ffffff06 : #00000007;
    // ── NavItem 选中状态 ──────────────────────────────────────
    out property <color> nav-sel:       ThemeState.dark ? #6b8aff18 : #0071e314;
    out property <color> nav-sel-hi:    ThemeState.dark ? #6b8aff24 : #0071e320;
    out property <color> nav-sel-bdr:   ThemeState.dark ? #6b8aff35 : #0071e328;
    out property <color> nav-sel-glow:  ThemeState.dark ? #4c6ef535 : #0071e325;
    out property <color> nav-hover:     ThemeState.dark ? #ffffff0a : #0000000a;
    // ── 主色 + 光晕 ──────────────────────────────────────────
    out property <color> primary:       ThemeState.dark ? #6b8aff   : #0071e3;
    out property <color> primary-h:     ThemeState.dark ? #4f6fe8   : #005bbf;
    out property <color> primary-light: ThemeState.dark ? #8ba3ff   : #1a82ff;
    out property <color> primary-glow:  ThemeState.dark ? #4c6ef550 : #0071e330;
    // ── 文字 ─────────────────────────────────────────────────
    out property <color> text:          ThemeState.dark ? #c8cad2 : #1d1d1f;
    out property <color> text-dim:      ThemeState.dark ? #6b7280 : #6e6e73;
    out property <color> text-bright:   ThemeState.dark ? #eef0f8 : #000000;
    // ── 状态 + 光晕 ──────────────────────────────────────────
    out property <color> success:       ThemeState.dark ? #3ecf6e   : #34c759;
    out property <color> success-glow:  ThemeState.dark ? #3ecf6e50 : #34c75930;
    out property <color> error:         ThemeState.dark ? #ff6b6b   : #ff3b30;
    out property <color> error-glow:    ThemeState.dark ? #ff6b6b40 : #ff3b3030;
    out property <color> warning:       ThemeState.dark ? #f5a623   : #ff9500;
    // ── 液态玻璃高光 + 背景色球 ─────────────────────────────────
    out property <color> specular:     ThemeState.dark ? #ffffff1e : #ffffff70;
    out property <color> orb-a:        ThemeState.dark ? #4c6ef52a : #0071e316;
    out property <color> orb-b:        ThemeState.dark ? #7c3aed24 : #5856d614;
    out property <color> orb-c:        ThemeState.dark ? #0ea5e91c : #34aadc10;
}

// ─────────────────────────────────────────────────────────────
// 基础组件
// ─────────────────────────────────────────────────────────────

component Card inherits Rectangle {
    clip: true;
    border-radius: 20px;
    background: @linear-gradient(160deg, Palette.card-from, Palette.card-to);
    border-width: 1px;
    border-color: Palette.border;
    drop-shadow-blur: 28px;
    drop-shadow-offset-y: 8px;
    drop-shadow-color: ThemeState.dark ? #00000070 : #0000001a;

    // 用户内容先渲染（在下层）
    @children

    // 镜面高光层——叠加在内容之上，模拟玻璃折射
    Rectangle {
        x: 0;
        y: 0;
        width: root.width;
        height: 54px;
        border-radius: 18px;
        background: @linear-gradient(180deg, Palette.specular, #00000000);
    }
}

component PBtn inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <bool> danger:  false;
    in property <bool> small:   false;
    callback clicked;

    height: small ? 28px : 36px;
    // 全胶囊圆角
    border-radius: root.height / 2;
    background: !enabled                ? @linear-gradient(180deg, Palette.btn-dis-from, Palette.btn-dis-to)
              : danger && ta.has-hover  ? @linear-gradient(180deg, #ff8585, #e03131)
              : danger                  ? @linear-gradient(180deg, #ff6b6b, #cc2929)
              : ta.has-hover            ? @linear-gradient(180deg, Palette.primary-light, Palette.primary-h)
              :                          @linear-gradient(180deg, Palette.primary, Palette.primary-h);
    border-width: 1px;
    border-color: !enabled ? #ffffff0e : ta.has-hover ? Palette.border-hi : #ffffff2a;
    // 悬停时产生蓝/红光晕
    drop-shadow-blur:    ta.has-hover && enabled ? 20px : 5px;
    drop-shadow-offset-y: 2px;
    drop-shadow-color: !enabled ? #00000000
                     : danger   ? Palette.error-glow
                     :            Palette.primary-glow;

    animate drop-shadow-blur  { duration: 220ms; easing: ease-out; }
    animate border-color      { duration: 150ms; }

    Text {
        text: root.text;
        color: root.enabled ? Palette.text-bright : Palette.text-dim;
        font-size: root.small ? 11px : 13px;
        font-weight: 600;
        letter-spacing: 0.3px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => { root.clicked(); }
    }
}

component GhostBtn inherits Rectangle {
    in property <string> text;
    in property <bool> danger: false;
    callback clicked;

    height: 32px;
    border-radius: 10px;
    border-width: 1px;
    border-color: danger ? Palette.error-glow : Palette.border;
    background: ta.has-hover ? (danger ? #ff6b6b18 : #6b8aff18) : Palette.surface2;

    animate border-color { duration: 150ms; }

    Text {
        text: root.text;
        color: root.danger ? Palette.error : Palette.text;
        font-size: 12px;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// 状态圆点（带光晕，模拟发光 LED）
component Dot inherits Rectangle {
    in property <bool> online;
    width: 9px;
    height: 9px;
    border-radius: 5px;
    background: online ? Palette.success : Palette.error;
    drop-shadow-blur: online ? 10px : 4px;
    drop-shadow-color: online ? Palette.success-glow : Palette.error-glow;
    animate background       { duration: 600ms; }
    animate drop-shadow-blur { duration: 600ms; }
}

component Label inherits Text {
    color: Palette.text-dim;
    font-size: 12px;
}

component Input inherits Rectangle {
    in-out property <string> value <=> le.text;
    in property <string> placeholder;
    in property <bool> password: false;
    in property <bool> enabled:  true;
    height: 36px;
    border-radius: 10px;
    border-width: 1px;
    border-color: le.has-focus ? Palette.border-hi : Palette.border;
    background: le.has-focus ? Palette.surface-focus : Palette.surface;
    drop-shadow-blur: le.has-focus ? 12px : 0px;
    drop-shadow-color: Palette.primary-glow;

    animate border-color     { duration: 180ms; }
    animate drop-shadow-blur { duration: 180ms; }

    le := LineEdit {
        x: 10px;
        y: 0;
        width: root.width - 20px;
        height: root.height;
        placeholder-text: root.placeholder;
        input-type: root.password ? InputType.password : InputType.text;
        enabled: root.enabled;
        font-size: 13px;
    }
}

component Divider inherits Rectangle {
    height: 1px;
    // 两端渐隐，避免硬边界
    background: @linear-gradient(90deg, #ffffff00, Palette.border, #ffffff00);
}

// 导航项（液态玻璃胶囊高亮）
component NavItem inherits TouchArea {
    in property <string> icon;
    in property <string> label;
    in property <bool> selected;
    height: 44px;
    mouse-cursor: pointer;

    // 玻璃胶囊背景
    Rectangle {
        x: 6px;
        y: 4px;
        width: parent.width - 12px;
        height: parent.height - 8px;
        border-radius: 12px;
        background: root.selected && root.has-hover ? Palette.nav-sel-hi
                  : root.selected                   ? Palette.nav-sel
                  : root.has-hover                  ? Palette.nav-hover
                  :                                   transparent;
        border-width: root.selected ? 1px : 0px;
        border-color: root.selected ? Palette.nav-sel-bdr : transparent;
        drop-shadow-blur: root.selected ? 16px : 0px;
        drop-shadow-color: Palette.nav-sel-glow;

        animate drop-shadow-blur { duration: 250ms; easing: ease-out; }

        HorizontalLayout {
            padding-left: 12px;
            padding-right: 8px;
            spacing: 10px;
            alignment: start;

            Text {
                text: root.icon;
                color: root.selected ? Palette.primary : Palette.text-dim;
                font-size: 17px;
                // Windows 的 femtovg 不自动回退系统符号字体；macOS 上找不到此字体时自动回退无影响
                font-family: "Segoe UI Symbol";
                vertical-alignment: center;
                width: 22px;
                animate color { duration: 200ms; }
            }

            Text {
                text: root.label;
                color: root.selected ? Palette.text-bright : Palette.text-dim;
                font-size: 13px;
                font-weight: root.selected ? 600 : 400;
                letter-spacing: root.selected ? 0.3px : 0px;
                vertical-alignment: center;
                animate color { duration: 200ms; }
            }
        }
    }
}

// 状态消息行（success=true → 绿，false → 红）
component StatusMsg inherits Text {
    in property <string> msg;
    in property <bool> ok;
    visible: msg != "";
    text: msg;
    color: ok ? Palette.success : Palette.error;
    font-size: 13px;
    wrap: word-wrap;
}

// ─────────────────────────────────────────────────────────────
// 页面 1：首页 Dashboard
// ─────────────────────────────────────────────────────────────

component DashboardPage inherits VerticalLayout {
    in property <bool> online;
    in property <string> peer-id;
    in property <string> nat-type;
    in property <string> server-addr;
    in property <bool> logged-in;
    in property <string> username;
    in property <string> role;
    in property <string> token-remaining;
    in-out property <string> quick-peer-id;
    in-out property <string> quick-local-port: "0";
    in property <bool> connecting;
    in property <string> connect-result;
    in property <bool> connect-ok;

    callback do-connect(string, string);
    callback do-refresh();

    spacing: 0px;
    padding: 24px;

    HorizontalLayout {
        height: 36px;
        Text {
            text: Tr.dashboard_title;
            color: Palette.text-bright;
            font-size: 20px;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }

        GhostBtn {
            text: Tr.btn_refresh;
            width: 72px;
            clicked => {
                root.do-refresh();
            }
        }
    }

    Rectangle {
        height: 16px;
    }

    // 状态卡片行
    HorizontalLayout {
        spacing: 12px;
        height: 106px;

        Card {
            horizontal-stretch: 1;
            VerticalLayout {
                padding: 16px;
                spacing: 8px;
                alignment: start;
                Label {
                    text: Tr.dashboard_server;
                }

                HorizontalLayout {
                    spacing: 8px;
                    Dot {
                        online: root.online;
                        y: 6px;
                    }

                    Text {
                        text: root.online ? Tr.dashboard_online : Tr.dashboard_offline;
                        color: root.online ? Palette.success : Palette.error;
                        font-size: 18px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }

                Label {
                    text: root.server-addr;
                }
            }
        }

        Card {
            horizontal-stretch: 2;
            VerticalLayout {
                padding: 16px;
                spacing: 8px;
                alignment: start;
                Label {
                    text: Tr.dashboard_peer_id;
                }

                Text {
                    text: root.peer-id == "" ? "—" : root.peer-id;
                    color: Palette.text-bright;
                    font-size: 26px;
                    font-weight: 700;
                    letter-spacing: 3px;
                }
            }
        }

        Card {
            horizontal-stretch: 1;
            VerticalLayout {
                padding: 16px;
                spacing: 8px;
                alignment: start;
                Label {
                    text: Tr.dashboard_nat_type;
                }

                Text {
                    text: root.nat-type;
                    color: Palette.text;
                    font-size: 15px;
                    font-weight: 600;
                }
            }
        }
    }

    Rectangle {
        height: 12px;
    }

    // 账户卡片
    Card {
        height: 76px;
        VerticalLayout {
            padding: 16px;
            spacing: 4px;
            alignment: start;
            Label {
                text: Tr.account_title;
            }

            Text {
                text: root.logged-in ? ("✓  " + root.username + "   [" + root.role + "]") : Tr.status_offline;
                color: root.logged-in ? Palette.success : Palette.text-dim;
                font-size: 14px;
                font-weight: 600;
            }

            if root.logged-in: Label {
                text: Tr.account_token_remaining + root.token-remaining;
            }
        }
    }

    Rectangle {
        height: 12px;
    }

    // 快速连接
    Card {
        VerticalLayout {
            padding: 20px;
            spacing: 14px;
            Text {
                text: Tr.conn_title;
                color: Palette.text-bright;
                font-size: 16px;
                font-weight: 600;
            }

            HorizontalLayout {
                spacing: 10px;
                height: 36px;
                Input {
                    horizontal-stretch: 3;
                    value <=> root.quick-peer-id;
                    placeholder: Tr.conn_input_peer_id;
                }

                Input {
                    horizontal-stretch: 1;
                    value <=> root.quick-local-port;
                    placeholder: Tr.conn_input_port;
                }

                PBtn {
                    text: root.connecting ? Tr.status_processing : Tr.btn_connect;
                    enabled: !root.connecting && root.quick-peer-id != "";
                    width: 90px;
                    clicked => {
                        root.do-connect(root.quick-peer-id, root.quick-local-port);
                    }
                }
            }

            if root.connect-result != "": StatusMsg {
                msg: root.connect-result;
                ok: root.connect-ok;
            }
        }
    }

    Rectangle {
        vertical-stretch: 1;
    }
}

// ─────────────────────────────────────────────────────────────
// 页面 2：活跃连接
// ─────────────────────────────────────────────────────────────

component ConnectionsPage inherits VerticalLayout {
    in property <[ActiveConn]> items;
    callback close-conn(string);

    spacing: 0px;
    padding: 24px;

    Text {
        text: Tr.conn_title;
        color: Palette.text-bright;
        font-size: 20px;
        font-weight: 700;
        height: 36px;
        vertical-alignment: center;
    }

    Rectangle {
        height: 16px;
    }

    if items.length == 0: Rectangle {
        vertical-stretch: 1;
        Text {
            text: Tr.conn_no_connections;
            color: Palette.text-dim;
            font-size: 15px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    if items.length > 0: ScrollView {
        vertical-stretch: 1;
        VerticalLayout {
            spacing: 10px;
            for item in root.items: Card {
                height: 110px;
                VerticalLayout {
                    padding: 14px;
                    spacing: 8px;
                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle {
                            width: 52px;
                            height: 22px;
                            border-radius: 4px;
                            background: item.conn-type == "Direct" ? #1864ab40 : #5c37ab40;
                            Text {
                                text: item.conn-type == "Direct" ? "直连" : "中继";
                                color: item.conn-type == "Direct" ? #74c0fc : #da77f2;
                                font-size: 11px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        Text {
                            text: item.peer-addr;
                            color: Palette.text-bright;
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        GhostBtn {
                            text: Tr.conn_close;
                            width: 56px;
                            danger: true;
                            clicked => {
                                root.close-conn(item.uuid);
                            }
                        }
                    }

                    Divider { }

                    HorizontalLayout {
                        spacing: 20px;
                        VerticalLayout {
                            Label {
                                text: Tr.conn_local_port;
                            }

                            Label {
                                text: item.local-port == 0 ? "—" : item.local-port;
                            }
                        }

                        VerticalLayout {
                            Label {
                                text: Tr.conn_sent;
                            }

                            Label {
                                text: item.bytes-sent;
                            }
                        }

                        VerticalLayout {
                            Label {
                                text: Tr.conn_recv;
                            }

                            Label {
                                text: item.bytes-recv;
                            }
                        }

                        VerticalLayout {
                            Label {
                                text: Tr.conn_type;
                            }

                            Label {
                                text: item.created-at;
                            }
                        }
                    }
                }
            }
        }
    }
}

// ─────────────────────────────────────────────────────────────
// 页面 3：局域网发现
// ─────────────────────────────────────────────────────────────

component PeersPage inherits VerticalLayout {
    in property <[LanPeer]> items;
    in property <bool> discovering;
    callback discover();
    callback connect-peer(string);

    spacing: 0px;
    padding: 24px;

    HorizontalLayout {
        height: 36px;
        Text {
            text: Tr.peers_title;
            color: Palette.text-bright;
            font-size: 20px;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }

        PBtn {
            text: root.discovering ? Tr.peers_scanning : Tr.peers_discover;
            enabled: !root.discovering;
            width: 100px;
            clicked => {
                root.discover();
            }
        }
    }

    Rectangle {
        height: 16px;
    }

    if items.length == 0: Rectangle {
        vertical-stretch: 1;
        VerticalLayout {
            alignment: center;
            spacing: 12px;
            Text {
                text: Tr.peers_no_peers;
                color: Palette.text-dim;
                font-size: 15px;
                horizontal-alignment: center;
            }

            Text {
                text: "";
                color: Palette.text-dim;
                font-size: 13px;
                horizontal-alignment: center;
            }
        }
    }

    if items.length > 0: ScrollView {
        vertical-stretch: 1;
        VerticalLayout {
            spacing: 10px;
            for item in root.items: Card {
                height: 80px;
                HorizontalLayout {
                    padding: 16px;
                    spacing: 14px;
                    alignment: start;
                    VerticalLayout {
                        alignment: center;
                        Dot {
                            online: item.online;
                        }
                    }

                    VerticalLayout {
                        horizontal-stretch: 1;
                        spacing: 4px;
                        alignment: center;
                        HorizontalLayout {
                            spacing: 10px;
                            Text {
                                text: item.id;
                                color: Palette.text-bright;
                                font-size: 16px;
                                font-weight: 700;
                            }

                            Text {
                                text: item.hostname;
                                color: Palette.text-dim;
                                font-size: 13px;
                                vertical-alignment: center;
                            }
                        }

                        HorizontalLayout {
                            spacing: 12px;
                            Label {
                                text: item.ip;
                            }

                            Label {
                                text: item.username;
                            }

                            Label {
                                text: item.platform;
                            }
                        }
                    }

                    PBtn {
                        text: Tr.peers_connect;
                        width: 70px;
                        clicked => {
                            root.connect-peer(item.id);
                        }
                    }
                }
            }
        }
    }
}

// ─────────────────────────────────────────────────────────────
// 页面 4：账户管理
// ─────────────────────────────────────────────────────────────

component AccountPage inherits VerticalLayout {
    in property <bool> logged-in;
    in property <string> username;
    in property <string> role;
    in property <string> token-remaining;
    in property <string> sub-plan;
    in property <int> sub-device-used;
    in property <int> sub-device-limit;
    in property <string> sub-expires;
    in property <bool> busy;
    in property <string> status-msg;
    in property <bool> status-ok;
    in-out property <string> input-user;
    in-out property <string> input-pass;
    in-out property <string> input-email;
    in-out property <string> input-device-name;
    in-out property <string> input-old-pass;
    in-out property <string> input-new-pass;
    in-out property <bool> show-register;

    callback do-login();
    callback do-logout();
    callback do-register();
    callback do-change-password();
    callback toggle-register();

    spacing: 0px;
    padding: 24px;

    Text {
        text: Tr.account_title;
        color: Palette.text-bright;
        font-size: 20px;
        font-weight: 700;
        height: 36px;
        vertical-alignment: center;
    }

    Rectangle {
        height: 16px;
    }

    // ── 已登录 ──────────────────────────────────────────────
    if logged-in: VerticalLayout {
        spacing: 14px;
        Card {
            height: 120px;
            HorizontalLayout {
                padding: 20px;
                spacing: 14px;
                alignment: start;
                // 头像圆
                Rectangle {
                    width: 54px;
                    height: 54px;
                    border-radius: 27px;
                    background: Palette.primary;
                    Text {
                        text: "U";
                        color: white;
                        font-size: 24px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                VerticalLayout {
                    alignment: center;
                    spacing: 6px;
                    Text {
                        text: root.username;
                        color: Palette.text-bright;
                        font-size: 18px;
                        font-weight: 700;
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle {
                            width: 44px;
                            height: 20px;
                            border-radius: 4px;
                            background: root.role == "admin" ? #e67700 : #1864ab;
                            Text {
                                text: root.role;
                                color: white;
                                font-size: 11px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        Label {
                            text: Tr.account_token_remaining + root.token-remaining;
                            vertical-alignment: center;
                        }
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                }

                GhostBtn {
                    text: Tr.btn_logout;
                    width: 82px;
                    danger: true;
                    clicked => {
                        root.do-logout();
                    }
                }
            }
        }

        // 订阅信息
        Card {
            VerticalLayout {
                padding: 20px;
                spacing: 12px;
                HorizontalLayout {
                    Text {
                        text: Tr.account_sub_plan;
                        color: Palette.text-bright;
                        font-size: 15px;
                        font-weight: 600;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                    }
                    Rectangle {
                        width: 80px;
                        height: 22px;
                        border-radius: 4px;
                        background: #1864ab22;
                        Text {
                            text: root.sub-plan;
                            color: #1864ab;
                            font-size: 12px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
                HorizontalLayout {
                    spacing: 24px;
                    VerticalLayout {
                        spacing: 3px;
                        Label {
                            text: Tr.account_sub_device_usage;
                            font-size: 11px;
                            color: Palette.text-dim;
                        }
                        Text {
                            text: root.sub-device-limit > 0
                                ? root.sub-device-used + " / " + root.sub-device-limit + " 台"
                                : root.sub-device-used + " 台（不限）";
                            color: Palette.text-bright;
                            font-size: 14px;
                            font-weight: 600;
                        }
                    }
                    VerticalLayout {
                        spacing: 3px;
                        Label {
                            text: Tr.account_sub_expires;
                            font-size: 11px;
                            color: Palette.text-dim;
                        }
                        Text {
                            text: root.sub-expires == "" ? Tr.account_sub_forever : root.sub-expires;
                            color: Palette.text-bright;
                            font-size: 14px;
                            font-weight: 600;
                        }
                    }
                }
            }
        }

        // 修改密码
        Card {
            VerticalLayout {
                padding: 20px;
                spacing: 12px;
                Text {
                    text: Tr.account_change_password;
                    color: Palette.text-bright;
                    font-size: 15px;
                    font-weight: 600;
                }

                Input {
                    placeholder: Tr.account_old_password;
                    password: true;
                    value <=> root.input-old-pass;
                }

                Input {
                    placeholder: Tr.account_new_password;
                    password: true;
                    value <=> root.input-new-pass;
                }

                HorizontalLayout {
                    spacing: 10px;
                    height: 36px;
                    Rectangle {
                        horizontal-stretch: 1;
                    }

                    PBtn {
                        text: root.busy ? Tr.status_processing : Tr.btn_change_password;
                        enabled: !root.busy;
                        width: 100px;
                        clicked => {
                            root.do-change-password();
                        }
                    }
                }

                if root.status-msg != "": StatusMsg {
                    msg: root.status-msg;
                    ok: root.status-ok;
                }
            }
        }
    }

    // ── 未登录：登录/注册表单 ───────────────────────────────
    if !logged-in: Card {
        VerticalLayout {
            padding: 24px;
            spacing: 14px;
            HorizontalLayout {
                Text {
                    text: root.show-register ? Tr.btn_register : Tr.btn_login;
                    color: Palette.text-bright;
                    font-size: 18px;
                    font-weight: 700;
                    horizontal-stretch: 1;
                }

                TouchArea {
                    width: 100px;
                    mouse-cursor: pointer;
                    clicked => {
                        root.toggle-register();
                    }
                    Text {
                        text: root.show-register ? Tr.account_login_link : Tr.account_register_link;
                        color: Palette.primary;
                        font-size: 13px;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                    }
                }
            }

            Input {
                placeholder: Tr.account_username;
                value <=> root.input-user;
            }

            if root.show-register: Input {
                placeholder: Tr.account_email;
                value <=> root.input-email;
            }
            Input {
                placeholder: Tr.account_password;
                password: true;
                value <=> root.input-pass;
            }

            if root.show-register: Input {
                placeholder: Tr.account_device_name;
                value <=> root.input-device-name;
            }
            if root.status-msg != "": StatusMsg {
                msg: root.status-msg;
                ok: root.status-ok;
            }
            PBtn {
                text: root.busy ? Tr.status_processing : (root.show-register ? Tr.btn_register : Tr.btn_login);
                enabled: !root.busy && root.input-user != "" && root.input-pass != "";
                height: 40px;
                clicked => {
                    if root.show-register {
                        root.do-register();
                    } else {
                        root.do-login();
                    }
                }
            }
        }
    }
    Rectangle {
        vertical-stretch: 1;
    }
}

// ─────────────────────────────────────────────────────────────
// 页面 5：设备管理
// ─────────────────────────────────────────────────────────────

component DevicesPage inherits VerticalLayout {
    in property <[BoundDevice]> items;
    in property <bool> logged-in;
    in property <bool> loading;
    callback refresh();
    callback remove-device(string);

    spacing: 0px;
    padding: 24px;

    HorizontalLayout {
        height: 36px;
        Text {
            text: Tr.devices_title;
            color: Palette.text-bright;
            font-size: 20px;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }

        GhostBtn {
            text: root.loading ? Tr.status_loading : Tr.btn_refresh;
            width: 72px;
            clicked => {
                root.refresh();
            }
        }
    }

    Rectangle {
        height: 16px;
    }

    if !logged-in: Rectangle {
        vertical-stretch: 1;
        Text {
            text: Tr.account_title;
            color: Palette.text-dim;
            font-size: 15px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    if logged-in && items.length == 0: Rectangle {
        vertical-stretch: 1;
        Text {
            text: Tr.devices_no_devices;
            color: Palette.text-dim;
            font-size: 15px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    if logged-in && items.length > 0: ScrollView {
        vertical-stretch: 1;
        VerticalLayout {
            spacing: 10px;
            for item in root.items: Card {
                height: 78px;
                HorizontalLayout {
                    padding: 16px;
                    spacing: 12px;
                    alignment: start;
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 10px;
                            height: 10px;
                            border-radius: 5px;
                            background: item.is-online ? Palette.success : Palette.text-dim;
                        }
                    }

                    VerticalLayout {
                        horizontal-stretch: 1;
                        spacing: 4px;
                        alignment: center;
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            Text {
                                text: item.device-name;
                                color: Palette.text-bright;
                                font-size: 15px;
                                font-weight: 600;
                            }
                            Text {
                                text: item.is-online ? Tr.status_online : Tr.status_offline;
                                color: item.is-online ? Palette.success : Palette.text-dim;
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                        }

                        HorizontalLayout {
                            spacing: 16px;
                            Label {
                                text: "Peer ID: " + item.device-id;
                            }

                            Label {
                                text: "注册时间: " + item.created-at;
                            }
                        }
                    }

                    GhostBtn {
                        text: Tr.devices_remove;
                        width: 56px;
                        danger: true;
                        clicked => {
                            root.remove-device(item.device-id);
                        }
                    }
                }
            }
        }
    }
}

// ─────────────────────────────────────────────────────────────
// 页面 6：设置
// ─────────────────────────────────────────────────────────────

component SettingsPage inherits VerticalLayout {
    in-out property <string> server-addr;
    in-out property <string> api-url;
    in-out property <string> relay-server;
    in-out property <string> ipc-port-str;
    in property <string> status-msg;
    in property <bool> status-ok;
    in property <bool> busy;
    // 代理设置
    in-out property <bool> socks5-enabled;
    in-out property <string> socks5-exit-peer;
    in-out property <string> socks5-port-str: "1080";
    // 更新
    in property <string> update-current-ver;
    in property <string> update-latest-ver;
    in property <bool>   update-available;
    in property <string> update-changelog;
    in property <string> update-msg;
    in property <bool>   update-msg-ok;
    in property <bool>   update-checking;
    in property <bool>   update-downloading;
    in property <float>  update-progress;
    callback save();
    callback restart-mediator();
    callback open-config-file();
    callback set-language(string);
    callback toggle-socks5();
    callback save-proxy-settings();
    callback do-check-update();
    callback do-apply-update();

    spacing: 0px;
    padding: 24px;

    Text {
        text: Tr.settings_title;
        color: Palette.text-bright;
        font-size: 20px;
        font-weight: 700;
        height: 36px;
        vertical-alignment: center;
    }

    Rectangle {
        height: 16px;
    }

    Card {
        VerticalLayout {
            padding: 20px;
            spacing: 14px;
            Text {
                text: Tr.settings_title;
                color: Palette.text-bright;
                font-size: 15px;
                font-weight: 600;
            }

            VerticalLayout {
                spacing: 6px;
                Label {
                    text: Tr.settings_server;
                }

                Input {
                    placeholder: "host:21116";
                    value <=> root.server-addr;
                }
            }

            VerticalLayout {
                spacing: 6px;
                Label {
                    text: Tr.settings_relay;
                }

                Input {
                    placeholder: "host:21117";
                    value <=> root.relay-server;
                }
            }

            VerticalLayout {
                spacing: 6px;
                Label {
                    text: "API";
                }

                Input {
                    placeholder: "http://host:8080";
                    value <=> root.api-url;
                }
            }

            VerticalLayout {
                spacing: 6px;
                Label {
                    text: "IPC";
                }

                Input {
                    placeholder: "21114";
                    value <=> root.ipc-port-str;
                }
            }

            // 语言选择
            HorizontalLayout {
                height: 36px;
                spacing: 10px;
                alignment: start;
                Label {
                    text: Tr.settings_language + ":";
                    vertical-alignment: center;
                    width: 90px;
                }

                PBtn {
                    text: Tr.lang_zh;
                    width: 72px;
                    clicked => {
                        root.set-language("zh");
                    }
                }

                PBtn {
                    text: Tr.lang_en;
                    width: 72px;
                    clicked => {
                        root.set-language("en");
                    }
                }
            }

            if root.status-msg != "": StatusMsg {
                msg: root.status-msg;
                ok: root.status-ok;
            }
            HorizontalLayout {
                spacing: 10px;
                height: 36px;
                PBtn {
                    text: root.busy ? Tr.status_processing : Tr.settings_save;
                    enabled: !root.busy;
                    width: 100px;
                    clicked => {
                        root.save();
                    }
                }

                GhostBtn {
                    text: Tr.settings_server;
                    width: 90px;
                    clicked => {
                        root.restart-mediator();
                    }
                }

                GhostBtn {
                    text: Tr.settings_open_config;
                    width: 110px;
                    clicked => {
                        root.open-config-file();
                    }
                }
            }
        }
    }

    Rectangle {
        height: 16px;
    }

    // 代理设置卡片
    Text {
        text: "代理设置";
        color: Palette.text-bright;
        font-size: 15px;
        font-weight: 600;
        height: 30px;
        vertical-alignment: center;
    }

    Card {
        VerticalLayout {
            padding: 16px;
            spacing: 10px;

            // SOCKS5 开关
            HorizontalLayout {
                height: 32px;
                Label {
                    text: "SOCKS5 代理";
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                PBtn {
                    text: root.socks5-enabled ? "已启用" : "已禁用";
                    small: true;
                    width: 72px;
                    clicked => {
                        root.toggle-socks5();
                    }
                }
            }

            // 出口节点
            HorizontalLayout {
                height: 32px;
                spacing: 8px;
                Label {
                    text: "出口 Peer ID";
                    vertical-alignment: center;
                    width: 90px;
                }

                Input {
                    placeholder: "对端 Peer ID";
                    value <=> root.socks5-exit-peer;
                    horizontal-stretch: 1;
                }
            }

            // 本地端口
            HorizontalLayout {
                height: 32px;
                spacing: 8px;
                Label {
                    text: "本地端口";
                    vertical-alignment: center;
                    width: 90px;
                }

                Input {
                    placeholder: "1080";
                    value <=> root.socks5-port-str;
                    horizontal-stretch: 1;
                }
            }

            // 保存按钮
            HorizontalLayout {
                height: 36px;
                Rectangle {
                    horizontal-stretch: 1;
                }

                PBtn {
                    text: "保存代理设置";
                    width: 120px;
                    clicked => {
                        root.save-proxy-settings();
                    }
                }
            }
        }
    }

    Rectangle {
        height: 16px;
    }

    // ── 检查更新卡片 ──────────────────────────────────────────
    Text {
        text: "软件更新";
        color: Palette.text-bright;
        font-size: 15px;
        font-weight: 600;
        height: 30px;
        vertical-alignment: center;
    }

    Card {
        VerticalLayout {
            padding: 16px;
            spacing: 10px;

            // 当前版本 + 检查按钮
            HorizontalLayout {
                height: 34px;
                spacing: 10px;
                Text {
                    text: "当前版本：v" + root.update-current-ver;
                    color: Palette.text-dim;
                    font-size: 13px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                PBtn {
                    text: root.update-checking ? "检查中…" : "检查更新";
                    small: true;
                    width: 90px;
                    enabled: !root.update-checking && !root.update-downloading;
                    clicked => {
                        root.do-check-update();
                    }
                }
            }

            // 有新版本时显示
            if root.update-available: VerticalLayout {
                spacing: 8px;

                // 版本提示行
                HorizontalLayout {
                    height: 28px;
                    spacing: 8px;
                    alignment: start;
                    Rectangle {
                        width: 10px;
                        height: 10px;
                        border-radius: 5px;
                        background: Palette.success;
                        y: (28px - self.height) / 2;
                    }

                    Text {
                        text: "发现新版本 v" + root.update-latest-ver;
                        color: Palette.success;
                        font-size: 14px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }

                // 更新日志
                if root.update-changelog != "": Text {
                    text: root.update-changelog;
                    color: Palette.text-dim;
                    font-size: 12px;
                    wrap: word-wrap;
                }

                // 下载进度条
                if root.update-downloading: VerticalLayout {
                    spacing: 4px;
                    Rectangle {
                        height: 6px;
                        border-radius: 3px;
                        background: Palette.border;
                        Rectangle {
                            x: 0;
                            width: parent.width * root.update-progress;
                            height: parent.height;
                            border-radius: parent.border-radius;
                            background: Palette.primary;
                        }
                    }

                    Text {
                        text: "下载中 " + Math.round(root.update-progress * 100) + "%";
                        color: Palette.text-dim;
                        font-size: 11px;
                    }
                }

                // 安装按钮（下载期间隐藏）
                if !root.update-downloading: PBtn {
                    text: "下载并安装";
                    width: 120px;
                    clicked => {
                        root.do-apply-update();
                    }
                }
            }

            // 更新状态消息
            if root.update-msg != "": StatusMsg {
                msg: root.update-msg;
                ok: root.update-msg-ok;
            }
        }
    }

    Rectangle {
        vertical-stretch: 1;
    }
}

// ─────────────────────────────────────────────────────────────
// 代码块组件（深色终端风格，用于命令示例）
// ─────────────────────────────────────────────────────────────

component CodeLine inherits Rectangle {
    in property <string> code;
    height: 30px;
    border-radius: 7px;
    background: Palette.code-bg;
    border-width: 1px;
    border-color: Palette.border;
    HorizontalLayout {
        padding-left: 12px;
        alignment: start;
        Text {
            text: root.code;
            color: Palette.code-text;
            font-size: 11px;
            font-family: "Consolas";
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

// ─────────────────────────────────────────────────────────────
// 页面 7：隧道接入（第三方应用接入）
// ─────────────────────────────────────────────────────────────

component TunnelPage inherits VerticalLayout {
    // ── SOCKS5 状态（复用 AppWindow 已有属性）─────────────────
    in property <bool>   socks5-enabled;
    in property <string> socks5-port-str;
    in property <string> socks5-exit-peer;

    // ── 端口转发规则 ──────────────────────────────────────────
    in property <[ForwardRule]> rules;
    in property <bool>   rules-loading;

    // ── 新增规则输入 ──────────────────────────────────────────
    in-out property <string> new-name;
    in-out property <string> new-port;
    in-out property <string> new-host;
    in-out property <string> new-filter;

    // ── 状态消息 ──────────────────────────────────────────────
    in property <string> status-msg;
    in property <bool>   status-ok;

    callback toggle-socks5();
    callback refresh-rules();
    callback add-rule();
    callback remove-rule(string);

    spacing: 0px;
    padding: 24px;

    // 标题
    HorizontalLayout {
        height: 36px;
        Text {
            text: "隧道接入";
            color: Palette.text-bright;
            font-size: 20px;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }

    Rectangle { height: 16px; }

    // ── SOCKS5 代理卡片 ────────────────────────────────────────
    Card {
        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            // 标题行 + 开关
            HorizontalLayout {
                Text {
                    text: "SOCKS5 代理";
                    color: Palette.text-bright;
                    font-size: 15px;
                    font-weight: 600;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }
                PBtn {
                    text: root.socks5-enabled ? "已启用" : "已禁用";
                    width: 72px;
                    small: true;
                    clicked => { root.toggle-socks5(); }
                }
            }

            // 状态 + 代理地址
            HorizontalLayout {
                spacing: 10px;
                alignment: start;
                VerticalLayout {
                    alignment: center;
                    Dot { online: root.socks5-enabled; }
                }
                Text {
                    text: root.socks5-enabled
                        ? ("代理地址：127.0.0.1:" + root.socks5-port-str
                           + "    出口节点：" + (root.socks5-exit-peer == "" ? "（未配置，请在设置页填写）" : root.socks5-exit-peer))
                        : "代理未启用 —— 点击右上角开关启用，并在设置页配置出口节点";
                    color: root.socks5-enabled
                        ? (root.socks5-exit-peer == "" ? Palette.warning : Palette.text)
                        : Palette.text-dim;
                    font-size: 12px;
                    vertical-alignment: center;
                    wrap: word-wrap;
                }
            }

            Divider {}

            // 接入方式参考（第三方应用配置示例）
            Label { text: "让第三方应用走隧道 —— 配置 SOCKS5 代理示例："; }

            CodeLine { code: "curl  --socks5-hostname  127.0.0.1:" + root.socks5-port-str + "  <URL>"; }
            CodeLine { code: "git config --global http.proxy  socks5h://127.0.0.1:" + root.socks5-port-str; }
            CodeLine { code: "ssh  -o ProxyCommand='nc -X 5 -x 127.0.0.1:" + root.socks5-port-str + " %h %p'  user@host"; }

            HorizontalLayout {
                spacing: 6px;
                alignment: start;
                Label { text: "浏览器 / 全局：系统代理 → SOCKS5 → 127.0.0.1:" + root.socks5-port-str; }
            }
        }
    }

    Rectangle { height: 16px; }

    // ── 端口转发规则卡片 ───────────────────────────────────────
    Card {
        vertical-stretch: 1;
        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            // 标题行 + 刷新
            HorizontalLayout {
                Text {
                    text: "端口转发规则";
                    color: Palette.text-bright;
                    font-size: 15px;
                    font-weight: 600;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }
                GhostBtn {
                    text: root.rules-loading ? Tr.status_loading : Tr.btn_refresh;
                    width: 64px;
                    clicked => { root.refresh-rules(); }
                }
            }

            Label { text: "规则让对端可以访问你本机的指定服务（如 SSH、HTTP）。对端连入后流量自动转发到目标地址。"; }

            // 规则列表 —— 空态
            if root.rules.length == 0: Rectangle {
                height: 48px;
                border-radius: 10px;
                background: Palette.surface;
                Text {
                    text: "暂无规则，在下方添加第一条";
                    color: Palette.text-dim;
                    font-size: 13px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            // 规则列表 —— 有数据
            if root.rules.length > 0: VerticalLayout {
                spacing: 6px;
                for rule in root.rules: Rectangle {
                    height: 46px;
                    border-radius: 10px;
                    background: Palette.rule-bg;
                    border-width: 1px;
                    border-color: Palette.border;
                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 10px;
                        spacing: 8px;
                        alignment: start;

                        // 规则名称
                        Text {
                            text: rule.name;
                            color: Palette.text-bright;
                            font-size: 13px;
                            font-weight: 600;
                            vertical-alignment: center;
                            width: 72px;
                        }

                        Text {
                            text: "→";
                            color: Palette.primary;
                            font-size: 14px;
                            font-weight: 700;
                            vertical-alignment: center;
                        }

                        // 目标地址
                        Text {
                            text: rule.target-host + ":" + rule.target-port;
                            color: Palette.text;
                            font-size: 12px;
                            font-family: "Consolas";
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        // 对端过滤器标签
                        if rule.peer-id-filter != "": Rectangle {
                            width: 88px;
                            height: 22px;
                            border-radius: 5px;
                            background: #6b8aff18;
                            border-width: 1px;
                            border-color: #6b8aff30;
                            Text {
                                text: rule.peer-id-filter;
                                color: Palette.primary;
                                font-size: 10px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }

                        GhostBtn {
                            text: Tr.btn_delete;
                            width: 48px;
                            danger: true;
                            clicked => { root.remove-rule(rule.rule-id); }
                        }
                    }
                }
            }

            Divider {}

            // 添加新规则表单
            Text {
                text: "添加规则";
                color: Palette.text;
                font-size: 13px;
                font-weight: 600;
            }

            HorizontalLayout {
                spacing: 8px;
                height: 36px;
                Input {
                    horizontal-stretch: 1;
                    placeholder: "名称（如 SSH）";
                    value <=> root.new-name;
                }
                Input {
                    width: 88px;
                    placeholder: "目标端口";
                    value <=> root.new-port;
                }
                Input {
                    width: 130px;
                    placeholder: "目标主机";
                    value <=> root.new-host;
                }
                Input {
                    width: 120px;
                    placeholder: "限制对端（选填）";
                    value <=> root.new-filter;
                }
                PBtn {
                    text: Tr.btn_add;
                    width: 60px;
                    enabled: root.new-name != "" && root.new-port != "";
                    clicked => { root.add-rule(); }
                }
            }

            if root.status-msg != "": StatusMsg {
                msg: root.status-msg;
                ok: root.status-ok;
            }
        }
    }

    Rectangle { vertical-stretch: 1; }
}

// ─────────────────────────────────────────────────────────────
// 套餐数据结构
// ─────────────────────────────────────────────────────────────

export struct PlanItem {
    id: int,
    name: string,
    display-name: string,
    price-monthly: float,
    device-limit: int,
    speed-limit-kbps: int,
    description: string,
    is-current: bool,
}

// ─────────────────────────────────────────────────────────────
// 页面 7：订阅 / 收款
// ─────────────────────────────────────────────────────────────

component PaymentPage inherits VerticalLayout {
    in property <[PlanItem]> plans;
    in property <bool> loading;
    in property <string> status-msg;
    in property <bool> status-ok;
    // 支付宝二维码（Rust 端生成 slint::Image 后推入）
    in property <image> qr-image;
    in property <bool> qr-visible;
    in property <string> selected-plan-name;
    in property <float> selected-plan-price;
    // 当前支付方式：0 = 支付宝，1 = Stripe
    in-out property <int> pay-method: 0;

    callback refresh-plans();
    callback pay-alipay(int);   // plan_id
    callback pay-stripe(int);   // plan_id
    callback close-qr();

    spacing: 0px;
    padding: 24px;

    // ── 标题行 ────────────────────────────────────────────────
    HorizontalLayout {
        height: 36px;
        Text {
            text: "订阅套餐";
            color: Palette.text-bright;
            font-size: 20px;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
        GhostBtn {
            text: root.loading ? Tr.status_loading : Tr.btn_refresh;
            width: 72px;
            clicked => { root.refresh-plans(); }
        }
    }

    Rectangle { height: 16px; }

    // ── 套餐卡片网格 ──────────────────────────────────────────
    if root.plans.length == 0: Rectangle {
        height: 100px;
        Text {
            text: root.loading ? Tr.status_loading : "暂无套餐信息";
            color: Palette.text-dim;
            font-size: 14px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    if root.plans.length > 0: HorizontalLayout {
        spacing: 12px;
        for plan in root.plans: Card {
            horizontal-stretch: 1;
            VerticalLayout {
                padding: 18px;
                spacing: 10px;
                alignment: start;

                // 套餐名
                Text {
                    text: plan.display-name;
                    color: Palette.text-bright;
                    font-size: 15px;
                    font-weight: 700;
                }

                // 价格
                Text {
                    text: plan.price-monthly > 0
                        ? ("¥" + round(plan.price-monthly) + " /月")
                        : "免费";
                    color: plan.price-monthly > 0 ? Palette.primary : Palette.success;
                    font-size: 22px;
                    font-weight: 800;
                }

                // 设备数
                Label {
                    text: plan.device-limit > 0
                        ? ("最多 " + plan.device-limit + " 台设备")
                        : "无限设备";
                }

                // 限速
                Label {
                    text: plan.speed-limit-kbps > 0
                        ? ("限速 " + round(plan.speed-limit-kbps / 1024) + " Mbps")
                        : "不限速";
                }

                if plan.description != "": Label {
                    text: plan.description;
                    wrap: word-wrap;
                }

                Rectangle { vertical-stretch: 1; }

                // 当前套餐标签 or 支付按钮
                if plan.is-current: Rectangle {
                    height: 32px;
                    border-radius: 10px;
                    background: Palette.success-glow;
                    Text {
                        text: "当前套餐 ✓";
                        color: Palette.success;
                        font-size: 12px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                if !plan.is-current && plan.price-monthly > 0: VerticalLayout {
                    spacing: 6px;
                    // 支付宝按钮
                    PBtn {
                        text: "支付宝扫码";
                        height: 32px;
                        clicked => { root.pay-alipay(plan.id); }
                    }
                    // Stripe 按钮
                    GhostBtn {
                        text: "Stripe 信用卡";
                        clicked => { root.pay-stripe(plan.id); }
                    }
                }
            }
        }
    }

    Rectangle { height: 16px; }

    // ── 支付宝二维码卡片 ──────────────────────────────────────
    if root.qr-visible: Card {
        VerticalLayout {
            padding: 20px;
            spacing: 14px;
            alignment: center;

            HorizontalLayout {
                Text {
                    text: "支付宝扫码支付 — " + root.selected-plan-name;
                    color: Palette.text-bright;
                    font-size: 15px;
                    font-weight: 600;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }
                Text {
                    text: "¥" + round(root.selected-plan-price);
                    color: Palette.primary;
                    font-size: 18px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }

            Divider {}

            HorizontalLayout {
                alignment: center;
                Image {
                    source: root.qr-image;
                    width: 200px;
                    height: 200px;
                    image-rendering: pixelated;
                }
            }

            Label { text: "使用支付宝 App 扫描上方二维码完成支付"; horizontal-alignment: center; }

            if root.status-msg != "": StatusMsg {
                msg: root.status-msg;
                ok: root.status-ok;
            }

            HorizontalLayout {
                alignment: center;
                GhostBtn {
                    text: "关闭";
                    width: 80px;
                    clicked => { root.close-qr(); }
                }
            }
        }
    }

    if root.status-msg != "" && !root.qr-visible: StatusMsg {
        msg: root.status-msg;
        ok: root.status-ok;
    }

    Rectangle { vertical-stretch: 1; }
}

// ─────────────────────────────────────────────────────────────
// 主窗口
// ─────────────────────────────────────────────────────────────

export component AppWindow inherits Window {
    title: "NAT Client";
    preferred-width: 960px;
    preferred-height: 640px;
    background: @linear-gradient(145deg, Palette.bg, Palette.bg2);

    // 应用 Logo（由 Rust 启动时注入；同时用作 OS 窗口图标）
    in property <image> app-logo;
    icon: app-logo;

    // ── 状态属性 ──────────────────────────────────────────────
    in property <bool> online;
    in property <string> peer-id;
    in property <string> nat-type:   "未知";
    in property <string> server-addr;
    in property <bool> logged-in;
    in property <string> username;
    in property <string> role;
    in property <string> token-remaining;
    in property <string> sub-plan;
    in property <int> sub-device-used;
    in property <int> sub-device-limit;
    in property <string> sub-expires;
    in property <[ActiveConn]> connections;
    in property <[LanPeer]> lan-peers;
    in property <[BoundDevice]> devices;
    // ── 隧道接入 ──────────────────────────────────────────────
    in property <[ForwardRule]> tunnel-rules;
    in property <bool>   tunnel-rules-loading;
    in property <string> tunnel-status-msg;
    in property <bool>   tunnel-status-ok;
    in-out property <string> tunnel-new-name;
    in-out property <string> tunnel-new-port;
    in-out property <string> tunnel-new-host: "127.0.0.1";
    in-out property <string> tunnel-new-filter;
    // ── 订阅 / 收款 ──────────────────────────────────────────
    in property <[PlanItem]> pay-plans;
    in property <bool>   pay-loading;
    in property <string> pay-status-msg;
    in property <bool>   pay-status-ok;
    in property <image>  pay-qr-image;
    in property <bool>   pay-qr-visible;
    in property <string> pay-selected-plan-name;
    in property <float>  pay-selected-plan-price;

    // ── 更新 ──────────────────────────────────────────────────
    in property <string> update-current-ver: "";
    in property <string> update-latest-ver: "";
    in property <bool>   update-available;
    in property <string> update-changelog: "";
    in property <string> update-msg: "";
    in property <bool>   update-msg-ok;
    in property <bool>   update-checking;
    in property <bool>   update-downloading;
    in property <float>  update-progress;

    in property <bool> connecting;
    in property <bool> discovering;
    in property <bool> devices-loading;
    in property <bool> account-busy;
    in property <string> connect-result;
    in property <bool> connect-ok;
    in property <string> account-status;
    in property <bool> account-status-ok;
    in property <string> settings-status;
    in property <bool> settings-status-ok;

    // ── 设置字段（双向） ──────────────────────────────────────
    in-out property <string> cfg-server;
    in-out property <string> cfg-relay;
    in-out property <string> cfg-api-url;
    in-out property <string> cfg-ipc-port;

    // ── 代理设置字段（双向） ──────────────────────────────────
    in-out property <bool> socks5-enabled;
    in-out property <string> socks5-exit-peer;
    in-out property <string> socks5-port-str: "1080";

    // ── 输入字段（双向） ──────────────────────────────────────
    in-out property <string> quick-peer-id;
    in-out property <string> quick-local-port: "0";
    in-out property <string> login-user;
    in-out property <string> login-pass;
    in-out property <string> reg-email;
    in-out property <string> reg-device-name;
    in-out property <string> old-pass;
    in-out property <string> new-pass;
    in-out property <bool> show-register;

    // ── 导航 ──────────────────────────────────────────────────
    in-out property <int> page: 0;

    // ── 回调 ──────────────────────────────────────────────────
    callback do-connect(string, string);
    callback do-discover();
    callback do-refresh();
    callback close-conn(string);
    callback connect-peer(string);
    callback do-login();
    callback do-logout();
    callback do-register();
    callback do-change-password();
    callback do-remove-device(string);
    callback do-save-settings();
    callback do-restart-mediator();
    callback do-open-config();
    callback toggle-register();
    callback set-language(string);
    callback toggle-socks5();
    callback save-proxy-settings();
    callback do-add-rule();
    callback do-remove-rule(string);
    callback do-refresh-rules();
    callback do-toggle-theme();
    callback do-refresh-plans();
    callback do-pay-alipay(int);   // plan_id
    callback do-pay-stripe(int);   // plan_id
    callback do-close-qr();
    callback do-check-update();
    callback do-apply-update();

    // ── 布局 ──────────────────────────────────────────────────
    HorizontalLayout {

        // ── 侧边栏 ────────────────────────────────────────────
        Rectangle {
            width: 200px;
            background: @linear-gradient(180deg, Palette.sidebar-from, Palette.sidebar-to);

            VerticalLayout {
                padding: 12px;
                spacing: 4px;

                // Logo
                HorizontalLayout {
                    height: 60px;
                    padding-left: 12px;
                    spacing: 10px;
                    alignment: start;
                    // App Logo 图标
                    Rectangle {
                        width: 36px;
                        height: 36px;
                        border-radius: 10px;
                        clip: true;
                        drop-shadow-blur: 12px;
                        drop-shadow-color: #00000040;
                        Image {
                            source: root.app-logo;
                            width: 36px;
                            height: 36px;
                            image-fit: contain;
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        spacing: 2px;
                        Text {
                            text: "NAT Client";
                            color: Palette.text-bright;
                            font-size: 13px;
                            font-weight: 700;
                            letter-spacing: 0.5px;
                        }

                        Text {
                            text: "v0.1.0";
                            color: Palette.text-dim;
                            font-size: 10px;
                        }
                    }
                }

                Divider { }

                Rectangle {
                    height: 4px;
                }

                NavItem {
                    icon: "⊞";
                    label: Tr.nav_dashboard;
                    selected: page == 0;
                    clicked => {
                        root.page = 0;
                    }
                }

                NavItem {
                    icon: "⇄";
                    label: Tr.nav_connections;
                    selected: page == 1;
                    clicked => {
                        root.page = 1;
                    }
                }

                NavItem {
                    icon: "◉";
                    label: Tr.nav_peers;
                    selected: page == 2;
                    clicked => {
                        root.page = 2;
                    }
                }

                NavItem {
                    icon: "☺";
                    label: Tr.nav_account;
                    selected: page == 3;
                    clicked => {
                        root.page = 3;
                    }
                }

                NavItem {
                    icon: "▣";
                    label: Tr.nav_devices;
                    selected: page == 4;
                    clicked => {
                        root.page = 4;
                    }
                }

                NavItem {
                    icon: "⚙";
                    label: Tr.nav_settings;
                    selected: page == 5;
                    clicked => {
                        root.page = 5;
                    }
                }

                NavItem {
                    icon: "⇒";
                    label: "隧道接入";
                    selected: page == 6;
                    clicked => {
                        root.page = 6;
                        root.do-refresh-rules();
                    }
                }

                NavItem {
                    icon: "★";
                    label: "订阅套餐";
                    selected: page == 7;
                    clicked => {
                        root.page = 7;
                        root.do-refresh-plans();
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                Divider { }

                // 底部状态
                HorizontalLayout {
                    height: 36px;
                    padding-left: 16px;
                    spacing: 8px;
                    alignment: start;
                    VerticalLayout {
                        alignment: center;
                        Dot { online: root.online; }
                    }
                    Text {
                        text: root.online ? Tr.status_online : Tr.status_offline;
                        color: root.online ? Palette.success : Palette.text-dim;
                        font-size: 12px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }

                // 主题切换按钮
                theme-toggle := TouchArea {
                    height: 32px;
                    mouse-cursor: pointer;
                    clicked => { root.do-toggle-theme(); }

                    Rectangle {
                        border-radius: 8px;
                        background: theme-toggle.has-hover ? Palette.nav-hover : transparent;
                        HorizontalLayout {
                            padding-left: 16px;
                            spacing: 8px;
                            alignment: start;
                            Text {
                                text: ThemeState.dark ? "☀" : "◑";
                                font-family: "Segoe UI Symbol";
                                font-size: 13px;
                                color: Palette.text-dim;
                                vertical-alignment: center;
                                width: 18px;
                            }
                            Text {
                                text: ThemeState.dark ? "浅色模式" : "深色模式";
                                font-size: 11px;
                                color: Palette.text-dim;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        // ── 侧边栏右侧玻璃分割线 ─────────────────────────────
        Rectangle {
            width: 1px;
            background: @linear-gradient(180deg, transparent, Palette.divider-v-mid, Palette.divider-v-mid, transparent);
        }

        // ── 内容区 ────────────────────────────────────────────
        content-area := Rectangle {
            horizontal-stretch: 1;
            background: transparent;

            // 背景色球——让玻璃卡片有"颜色可采样"，模拟液态玻璃折射效果
            Rectangle {
                x: 20px;
                y: 30px;
                width: 380px;
                height: 380px;
                background: @radial-gradient(circle, Palette.orb-a, #00000000);
            }
            Rectangle {
                x: content-area.width - 340px;
                y: 10px;
                width: 340px;
                height: 340px;
                background: @radial-gradient(circle, Palette.orb-b, #00000000);
            }
            Rectangle {
                x: content-area.width - 200px;
                y: content-area.height - 240px;
                width: 300px;
                height: 300px;
                background: @radial-gradient(circle, Palette.orb-c, #00000000);
            }

            ScrollView {
                visible: page == 0;
                x: 0; y: 0;
                width: parent.width;
                height: parent.height;
                viewport-width: self.width;
                viewport-height: page0.preferred-height;
                page0 := DashboardPage {
                    width: parent.viewport-width;
                    online <=> root.online;
                    peer-id <=> root.peer-id;
                    nat-type <=> root.nat-type;
                    server-addr <=> root.server-addr;
                    logged-in <=> root.logged-in;
                    username <=> root.username;
                    role <=> root.role;
                    token-remaining <=> root.token-remaining;
                    quick-peer-id <=> root.quick-peer-id;
                    quick-local-port <=> root.quick-local-port;
                    connecting <=> root.connecting;
                    connect-result <=> root.connect-result;
                    connect-ok <=> root.connect-ok;
                    do-connect(id, port) => {
                        root.do-connect(id, port);
                    }
                    do-refresh => {
                        root.do-refresh();
                    }
                }
            }

            ScrollView {
                visible: page == 1;
                x: 0; y: 0;
                width: parent.width;
                height: parent.height;
                viewport-width: self.width;
                viewport-height: page1.preferred-height;
                page1 := ConnectionsPage {
                    width: parent.viewport-width;
                    items <=> root.connections;
                    close-conn(u) => {
                        root.close-conn(u);
                    }
                }
            }

            ScrollView {
                visible: page == 2;
                x: 0; y: 0;
                width: parent.width;
                height: parent.height;
                viewport-width: self.width;
                viewport-height: page2.preferred-height;
                page2 := PeersPage {
                    width: parent.viewport-width;
                    items <=> root.lan-peers;
                    discovering <=> root.discovering;
                    discover => {
                        root.do-discover();
                    }
                    connect-peer(id) => {
                        root.connect-peer(id);
                    }
                }
            }

            ScrollView {
                visible: page == 3;
                x: 0; y: 0;
                width: parent.width;
                height: parent.height;
                viewport-width: self.width;
                viewport-height: page3.preferred-height;
                page3 := AccountPage {
                    width: parent.viewport-width;
                    logged-in <=> root.logged-in;
                    username <=> root.username;
                    role <=> root.role;
                    token-remaining <=> root.token-remaining;
                    sub-plan <=> root.sub-plan;
                    sub-device-used <=> root.sub-device-used;
                    sub-device-limit <=> root.sub-device-limit;
                    sub-expires <=> root.sub-expires;
                    busy <=> root.account-busy;
                    status-msg <=> root.account-status;
                    status-ok <=> root.account-status-ok;
                    input-user <=> root.login-user;
                    input-pass <=> root.login-pass;
                    input-email <=> root.reg-email;
                    input-device-name <=> root.reg-device-name;
                    input-old-pass <=> root.old-pass;
                    input-new-pass <=> root.new-pass;
                    show-register <=> root.show-register;
                    do-login => {
                        root.do-login();
                    }
                    do-logout => {
                        root.do-logout();
                    }
                    do-register => {
                        root.do-register();
                    }
                    do-change-password => {
                        root.do-change-password();
                    }
                    toggle-register => {
                        root.toggle-register();
                    }
                }
            }

            ScrollView {
                visible: page == 4;
                x: 0; y: 0;
                width: parent.width;
                height: parent.height;
                viewport-width: self.width;
                viewport-height: page4.preferred-height;
                page4 := DevicesPage {
                    width: parent.viewport-width;
                    items <=> root.devices;
                    logged-in <=> root.logged-in;
                    loading <=> root.devices-loading;
                    refresh => {
                        root.do-refresh();
                    }
                    remove-device(id) => {
                        root.do-remove-device(id);
                    }
                }
            }

            ScrollView {
                visible: page == 5;
                x: 0; y: 0;
                width: parent.width;
                height: parent.height;
                viewport-width: self.width;
                viewport-height: page5.preferred-height;
                page5 := SettingsPage {
                    width: parent.viewport-width;
                    server-addr <=> root.cfg-server;
                    relay-server <=> root.cfg-relay;
                    api-url <=> root.cfg-api-url;
                    ipc-port-str <=> root.cfg-ipc-port;
                    status-msg <=> root.settings-status;
                    status-ok <=> root.settings-status-ok;
                    busy <=> root.account-busy;
                    socks5-enabled <=> root.socks5-enabled;
                    socks5-exit-peer <=> root.socks5-exit-peer;
                    socks5-port-str <=> root.socks5-port-str;
                    save => {
                        root.do-save-settings();
                    }
                    restart-mediator => {
                        root.do-restart-mediator();
                    }
                    open-config-file => {
                        root.do-open-config();
                    }
                    set-language(lang) => {
                        root.set-language(lang);
                    }
                    toggle-socks5 => {
                        root.toggle-socks5();
                    }
                    save-proxy-settings => {
                        root.save-proxy-settings();
                    }
                    update-current-ver <=> root.update-current-ver;
                    update-latest-ver  <=> root.update-latest-ver;
                    update-available   <=> root.update-available;
                    update-changelog   <=> root.update-changelog;
                    update-msg         <=> root.update-msg;
                    update-msg-ok      <=> root.update-msg-ok;
                    update-checking    <=> root.update-checking;
                    update-downloading <=> root.update-downloading;
                    update-progress    <=> root.update-progress;
                    do-check-update => { root.do-check-update(); }
                    do-apply-update => { root.do-apply-update(); }
                }
            }

            ScrollView {
                visible: page == 6;
                x: 0; y: 0;
                width: parent.width;
                height: parent.height;
                viewport-width: self.width;
                viewport-height: page6.preferred-height;
                page6 := TunnelPage {
                    width: parent.viewport-width;
                    socks5-enabled <=> root.socks5-enabled;
                    socks5-port-str <=> root.socks5-port-str;
                    socks5-exit-peer <=> root.socks5-exit-peer;
                    rules <=> root.tunnel-rules;
                    rules-loading <=> root.tunnel-rules-loading;
                    new-name <=> root.tunnel-new-name;
                    new-port <=> root.tunnel-new-port;
                    new-host <=> root.tunnel-new-host;
                    new-filter <=> root.tunnel-new-filter;
                    status-msg <=> root.tunnel-status-msg;
                    status-ok <=> root.tunnel-status-ok;
                    toggle-socks5 => { root.toggle-socks5(); }
                    refresh-rules => { root.do-refresh-rules(); }
                    add-rule => { root.do-add-rule(); }
                    remove-rule(id) => { root.do-remove-rule(id); }
                }
            }

            ScrollView {
                visible: page == 7;
                x: 0; y: 0;
                width: parent.width;
                height: parent.height;
                viewport-width: self.width;
                viewport-height: page7.preferred-height;
                page7 := PaymentPage {
                    width: parent.viewport-width;
                    plans <=> root.pay-plans;
                    loading <=> root.pay-loading;
                    status-msg <=> root.pay-status-msg;
                    status-ok <=> root.pay-status-ok;
                    qr-image <=> root.pay-qr-image;
                    qr-visible <=> root.pay-qr-visible;
                    selected-plan-name <=> root.pay-selected-plan-name;
                    selected-plan-price <=> root.pay-selected-plan-price;
                    refresh-plans => { root.do-refresh-plans(); }
                    pay-alipay(id) => { root.do-pay-alipay(id); }
                    pay-stripe(id) => { root.do-pay-stripe(id); }
                    close-qr => { root.do-close-qr(); }
                }
            }
        }
    }
}
