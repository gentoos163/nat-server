// ============================================================
//  NAT Client — 桌面 GUI (Slint 1.16)
//  深色主题，左侧导航，6 个功能页面
//  注意：Slint 字符串无 is-empty() / starts-with() / slice()
//        用 s == "" 代替 is-empty()，颜色通过独立 bool 属性控制
// ============================================================

import { Button, LineEdit, ScrollView, Spinner } from "std-widgets.slint";

// ─────────────────────────────────────────────────────────────
// 翻译 global（由 Rust 根据当前语言设置所有属性）
// ─────────────────────────────────────────────────────────────

export global Tr {
    in property <string> nav_dashboard: "首页";
    in property <string> nav_connections: "连接";
    in property <string> nav_peers: "局域网";
    in property <string> nav_account: "账户";
    in property <string> nav_devices: "设备";
    in property <string> nav_settings: "设置";

    in property <string> btn_save: "保存";
    in property <string> btn_cancel: "取消";
    in property <string> btn_refresh: "刷新";
    in property <string> btn_add: "新增";
    in property <string> btn_delete: "删除";
    in property <string> btn_connect: "连接";
    in property <string> btn_login: "登录";
    in property <string> btn_logout: "退出登录";
    in property <string> btn_register: "注册";
    in property <string> btn_change_password: "确认修改";

    in property <string> status_online: "在线";
    in property <string> status_offline: "离线";
    in property <string> status_loading: "加载中…";
    in property <string> status_processing: "处理中…";

    in property <string> dashboard_title: "首页";
    in property <string> dashboard_peer_id: "设备 ID";
    in property <string> dashboard_server: "服务器";
    in property <string> dashboard_nat_type: "NAT 类型";
    in property <string> dashboard_online: "在线";
    in property <string> dashboard_offline: "离线";

    in property <string> conn_title: "连接";
    in property <string> conn_peer_id: "Peer ID";
    in property <string> conn_local_port: "本地端口";
    in property <string> conn_type: "类型";
    in property <string> conn_sent: "发送";
    in property <string> conn_recv: "接收";
    in property <string> conn_close: "断开";
    in property <string> conn_no_connections: "暂无活跃连接";
    in property <string> conn_input_peer_id: "目标 Peer ID";
    in property <string> conn_input_port: "本地端口（0=自动）";

    in property <string> peers_title: "局域网";
    in property <string> peers_scanning: "扫描中…";
    in property <string> peers_discover: "扫描";
    in property <string> peers_no_peers: "未发现局域网节点";
    in property <string> peers_connect: "连接";

    in property <string> account_title: "账户";
    in property <string> account_username: "用户名";
    in property <string> account_password: "密码";
    in property <string> account_email: "邮箱";
    in property <string> account_device_name: "设备名称（可选）";
    in property <string> account_old_password: "旧密码";
    in property <string> account_new_password: "新密码";
    in property <string> account_change_password: "修改密码";
    in property <string> account_token_remaining: "Token 剩余：";
    in property <string> account_register_link: "注册账户 →";
    in property <string> account_login_link: "← 返回登录";
    in property <string> account_sub_plan: "我的套餐";
    in property <string> account_sub_current: "当前套餐";
    in property <string> account_sub_device_usage: "设备使用";
    in property <string> account_sub_expires: "到期时间";
    in property <string> account_sub_forever: "永久";

    in property <string> devices_title: "设备";
    in property <string> devices_id: "设备 ID";
    in property <string> devices_name: "名称";
    in property <string> devices_remove: "移除";
    in property <string> devices_no_devices: "暂无绑定设备";

    in property <string> settings_title: "设置";
    in property <string> settings_server: "服务器地址";
    in property <string> settings_relay: "中继服务器";
    in property <string> settings_peer_id: "设备 ID";
    in property <string> settings_protocol: "协议";
    in property <string> settings_language: "界面语言";
    in property <string> settings_open_config: "打开配置文件";
    in property <string> settings_save: "保存设置";
    in property <string> lang_zh: "中文";
    in property <string> lang_en: "English";
}

// ─────────────────────────────────────────────────────────────
// 数据结构
// ─────────────────────────────────────────────────────────────

export struct LanPeer {
    id: string,
    ip: string,
    hostname: string,
    username: string,
    platform: string,
    online: bool,
}

export struct ActiveConn {
    uuid: string,
    conn-type: string,
    peer-addr: string,
    local-port: int,
    bytes-sent: string,
    bytes-recv: string,
    created-at: string,
}

export struct BoundDevice {
    id: int,
    device-id: string,
    device-name: string,
    is-active: bool,
    created-at: string,
}

// ─────────────────────────────────────────────────────────────
// 调色板
// ─────────────────────────────────────────────────────────────

global Palette {
    // ── 深色玻璃背景 ─────────────────────────────────────────
    out property <color> bg:           #070a13;
    out property <color> sidebar:      #05070d;
    // ── 玻璃层 ───────────────────────────────────────────────
    out property <color> card:         #ffffff0c;
    out property <color> border:       #ffffff20;
    out property <color> border-hi:    #ffffff44;
    out property <color> surface:      #ffffff09;
    // ── 主色 + 光晕 ──────────────────────────────────────────
    out property <color> primary:      #6b8aff;
    out property <color> primary-h:    #4f6fe8;
    out property <color> primary-glow: #4c6ef550;
    // ── 文字 ─────────────────────────────────────────────────
    out property <color> text:         #c8cad2;
    out property <color> text-dim:     #6b7280;
    out property <color> text-bright:  #eef0f8;
    // ── 状态 + 光晕 ──────────────────────────────────────────
    out property <color> success:      #3ecf6e;
    out property <color> success-glow: #3ecf6e50;
    out property <color> error:        #ff6b6b;
    out property <color> error-glow:   #ff6b6b40;
    out property <color> warning:      #f5a623;
}

// ─────────────────────────────────────────────────────────────
// 基础组件
// ─────────────────────────────────────────────────────────────

component Card inherits Rectangle {
    clip: true;
    border-radius: 20px;
    // 顶部亮 → 底部暗，模拟光线从上方打在玻璃表面
    background: @linear-gradient(160deg, #ffffff11, #ffffff06);
    border-width: 1px;
    border-color: Palette.border;
    drop-shadow-blur: 28px;
    drop-shadow-offset-y: 8px;
    drop-shadow-color: #00000070;
}

component PBtn inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <bool> danger:  false;
    in property <bool> small:   false;
    callback clicked;

    height: small ? 28px : 36px;
    // 全胶囊圆角
    border-radius: root.height / 2;
    background: !enabled                ? @linear-gradient(180deg, #ffffff0d, #ffffff06)
              : danger && ta.has-hover  ? @linear-gradient(180deg, #ff8585, #e03131)
              : danger                  ? @linear-gradient(180deg, #ff6b6b, #cc2929)
              : ta.has-hover            ? @linear-gradient(180deg, #8ba3ff, #4f6fe8)
              :                          @linear-gradient(180deg, #6b8aff, #4f6fe8);
    border-width: 1px;
    border-color: !enabled ? #ffffff0e : ta.has-hover ? Palette.border-hi : #ffffff2a;
    // 悬停时产生蓝/红光晕
    drop-shadow-blur:    ta.has-hover && enabled ? 20px : 5px;
    drop-shadow-offset-y: 2px;
    drop-shadow-color: !enabled ? #00000000
                     : danger   ? Palette.error-glow
                     :            Palette.primary-glow;

    animate drop-shadow-blur  { duration: 220ms; easing: ease-out; }
    animate border-color      { duration: 150ms; }

    Text {
        text: root.text;
        color: root.enabled ? Palette.text-bright : Palette.text-dim;
        font-size: root.small ? 11px : 13px;
        font-weight: 600;
        letter-spacing: 0.3px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => { root.clicked(); }
    }
}

component GhostBtn inherits Rectangle {
    in property <string> text;
    in property <bool> danger: false;
    callback clicked;

    height: 32px;
    border-radius: 10px;
    border-width: 1px;
    border-color: danger ? Palette.error-glow : Palette.border;
    background: ta.has-hover ? (danger ? #ff6b6b18 : #6b8aff18) : #ffffff06;

    animate border-color { duration: 150ms; }

    Text {
        text: root.text;
        color: root.danger ? Palette.error : Palette.text;
        font-size: 12px;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// 状态圆点（带光晕，模拟发光 LED）
component Dot inherits Rectangle {
    in property <bool> online;
    width: 9px;
    height: 9px;
    border-radius: 5px;
    background: online ? Palette.success : Palette.error;
    drop-shadow-blur: online ? 10px : 4px;
    drop-shadow-color: online ? Palette.success-glow : Palette.error-glow;
    animate background       { duration: 600ms; }
    animate drop-shadow-blur { duration: 600ms; }
}

component Label inherits Text {
    color: Palette.text-dim;
    font-size: 12px;
}

component Input inherits Rectangle {
    in-out property <string> value <=> le.text;
    in property <string> placeholder;
    in property <bool> password: false;
    in property <bool> enabled:  true;
    height: 36px;
    border-radius: 10px;
    border-width: 1px;
    border-color: le.has-focus ? Palette.border-hi : Palette.border;
    background: le.has-focus ? #ffffff11 : Palette.surface;
    drop-shadow-blur: le.has-focus ? 12px : 0px;
    drop-shadow-color: Palette.primary-glow;

    animate border-color     { duration: 180ms; }
    animate drop-shadow-blur { duration: 180ms; }

    le := LineEdit {
        x: 10px;
        y: 0;
        width: root.width - 20px;
        height: root.height;
        placeholder-text: root.placeholder;
        input-type: root.password ? InputType.password : InputType.text;
        enabled: root.enabled;
        font-size: 13px;
    }
}

component Divider inherits Rectangle {
    height: 1px;
    // 两端渐隐，避免硬边界
    background: @linear-gradient(90deg, #ffffff00, Palette.border, #ffffff00);
}

// 导航项（液态玻璃胶囊高亮）
component NavItem inherits TouchArea {
    in property <string> icon;
    in property <string> label;
    in property <bool> selected;
    height: 44px;
    mouse-cursor: pointer;

    // 玻璃胶囊背景
    Rectangle {
        x: 6px;
        y: 4px;
        width: parent.width - 12px;
        height: parent.height - 8px;
        border-radius: 12px;
        background: root.selected && root.has-hover ? #6b8aff24
                  : root.selected                   ? #6b8aff18
                  : root.has-hover                  ? #ffffff0a
                  :                                   transparent;
        border-width: root.selected ? 1px : 0px;
        border-color: root.selected ? #6b8aff35 : transparent;
        drop-shadow-blur: root.selected ? 16px : 0px;
        drop-shadow-color: Palette.primary-glow;

        animate drop-shadow-blur { duration: 250ms; easing: ease-out; }

        HorizontalLayout {
            padding-left: 12px;
            padding-right: 8px;
            spacing: 10px;
            alignment: start;

            Text {
                text: root.icon;
                color: root.selected ? Palette.primary : Palette.text-dim;
                font-size: 17px;
                // Windows 的 femtovg 不自动回退系统符号字体；macOS 上找不到此字体时自动回退无影响
                font-family: "Segoe UI Symbol";
                vertical-alignment: center;
                width: 22px;
                animate color { duration: 200ms; }
            }

            Text {
                text: root.label;
                color: root.selected ? Palette.text-bright : Palette.text-dim;
                font-size: 13px;
                font-weight: root.selected ? 600 : 400;
                letter-spacing: root.selected ? 0.3px : 0px;
                vertical-alignment: center;
                animate color { duration: 200ms; }
            }
        }
    }
}

// 状态消息行（success=true → 绿，false → 红）
component StatusMsg inherits Text {
    in property <string> msg;
    in property <bool> ok;
    visible: msg != "";
    text: msg;
    color: ok ? Palette.success : Palette.error;
    font-size: 13px;
    wrap: word-wrap;
}

// ─────────────────────────────────────────────────────────────
// 页面 1：首页 Dashboard
// ─────────────────────────────────────────────────────────────

component DashboardPage inherits VerticalLayout {
    in property <bool> online;
    in property <string> peer-id;
    in property <string> nat-type;
    in property <string> server-addr;
    in property <bool> logged-in;
    in property <string> username;
    in property <string> role;
    in property <string> token-remaining;
    in-out property <string> quick-peer-id;
    in-out property <string> quick-local-port: "0";
    in property <bool> connecting;
    in property <string> connect-result;
    in property <bool> connect-ok;

    callback do-connect(string, string);
    callback do-refresh();

    spacing: 0px;
    padding: 24px;

    HorizontalLayout {
        height: 36px;
        Text {
            text: Tr.dashboard_title;
            color: Palette.text-bright;
            font-size: 20px;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }

        GhostBtn {
            text: Tr.btn_refresh;
            width: 72px;
            clicked => {
                root.do-refresh();
            }
        }
    }

    Rectangle {
        height: 16px;
    }

    // 状态卡片行
    HorizontalLayout {
        spacing: 12px;
        height: 106px;

        Card {
            horizontal-stretch: 1;
            VerticalLayout {
                padding: 16px;
                spacing: 8px;
                alignment: start;
                Label {
                    text: Tr.dashboard_server;
                }

                HorizontalLayout {
                    spacing: 8px;
                    Dot {
                        online: root.online;
                        y: 6px;
                    }

                    Text {
                        text: root.online ? Tr.dashboard_online : Tr.dashboard_offline;
                        color: root.online ? Palette.success : Palette.error;
                        font-size: 18px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }

                Label {
                    text: root.server-addr;
                }
            }
        }

        Card {
            horizontal-stretch: 2;
            VerticalLayout {
                padding: 16px;
                spacing: 8px;
                alignment: start;
                Label {
                    text: Tr.dashboard_peer_id;
                }

                Text {
                    text: root.peer-id == "" ? "—" : root.peer-id;
                    color: Palette.text-bright;
                    font-size: 26px;
                    font-weight: 700;
                    letter-spacing: 3px;
                }
            }
        }

        Card {
            horizontal-stretch: 1;
            VerticalLayout {
                padding: 16px;
                spacing: 8px;
                alignment: start;
                Label {
                    text: Tr.dashboard_nat_type;
                }

                Text {
                    text: root.nat-type;
                    color: Palette.text;
                    font-size: 15px;
                    font-weight: 600;
                }
            }
        }
    }

    Rectangle {
        height: 12px;
    }

    // 账户卡片
    Card {
        height: 76px;
        VerticalLayout {
            padding: 16px;
            spacing: 4px;
            alignment: start;
            Label {
                text: Tr.account_title;
            }

            Text {
                text: root.logged-in ? ("✓  " + root.username + "   [" + root.role + "]") : Tr.status_offline;
                color: root.logged-in ? Palette.success : Palette.text-dim;
                font-size: 14px;
                font-weight: 600;
            }

            if root.logged-in: Label {
                text: Tr.account_token_remaining + root.token-remaining;
            }
        }
    }

    Rectangle {
        height: 12px;
    }

    // 快速连接
    Card {
        VerticalLayout {
            padding: 20px;
            spacing: 14px;
            Text {
                text: Tr.conn_title;
                color: Palette.text-bright;
                font-size: 16px;
                font-weight: 600;
            }

            HorizontalLayout {
                spacing: 10px;
                height: 36px;
                Input {
                    horizontal-stretch: 3;
                    value <=> root.quick-peer-id;
                    placeholder: Tr.conn_input_peer_id;
                }

                Input {
                    horizontal-stretch: 1;
                    value <=> root.quick-local-port;
                    placeholder: Tr.conn_input_port;
                }

                PBtn {
                    text: root.connecting ? Tr.status_processing : Tr.btn_connect;
                    enabled: !root.connecting && root.quick-peer-id != "";
                    width: 90px;
                    clicked => {
                        root.do-connect(root.quick-peer-id, root.quick-local-port);
                    }
                }
            }

            if root.connect-result != "": StatusMsg {
                msg: root.connect-result;
                ok: root.connect-ok;
            }
        }
    }

    Rectangle {
        vertical-stretch: 1;
    }
}

// ─────────────────────────────────────────────────────────────
// 页面 2：活跃连接
// ─────────────────────────────────────────────────────────────

component ConnectionsPage inherits VerticalLayout {
    in property <[ActiveConn]> items;
    callback close-conn(string);

    spacing: 0px;
    padding: 24px;

    Text {
        text: Tr.conn_title;
        color: Palette.text-bright;
        font-size: 20px;
        font-weight: 700;
        height: 36px;
        vertical-alignment: center;
    }

    Rectangle {
        height: 16px;
    }

    if items.length == 0: Rectangle {
        vertical-stretch: 1;
        Text {
            text: Tr.conn_no_connections;
            color: Palette.text-dim;
            font-size: 15px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    if items.length > 0: ScrollView {
        vertical-stretch: 1;
        VerticalLayout {
            spacing: 10px;
            for item in root.items: Card {
                height: 110px;
                VerticalLayout {
                    padding: 14px;
                    spacing: 8px;
                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle {
                            width: 52px;
                            height: 22px;
                            border-radius: 4px;
                            background: item.conn-type == "Direct" ? #1864ab40 : #5c37ab40;
                            Text {
                                text: item.conn-type == "Direct" ? "直连" : "中继";
                                color: item.conn-type == "Direct" ? #74c0fc : #da77f2;
                                font-size: 11px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        Text {
                            text: item.peer-addr;
                            color: Palette.text-bright;
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        GhostBtn {
                            text: Tr.conn_close;
                            width: 56px;
                            danger: true;
                            clicked => {
                                root.close-conn(item.uuid);
                            }
                        }
                    }

                    Divider { }

                    HorizontalLayout {
                        spacing: 20px;
                        VerticalLayout {
                            Label {
                                text: Tr.conn_local_port;
                            }

                            Label {
                                text: item.local-port == 0 ? "—" : item.local-port;
                            }
                        }

                        VerticalLayout {
                            Label {
                                text: Tr.conn_sent;
                            }

                            Label {
                                text: item.bytes-sent;
                            }
                        }

                        VerticalLayout {
                            Label {
                                text: Tr.conn_recv;
                            }

                            Label {
                                text: item.bytes-recv;
                            }
                        }

                        VerticalLayout {
                            Label {
                                text: Tr.conn_type;
                            }

                            Label {
                                text: item.created-at;
                            }
                        }
                    }
                }
            }
        }
    }
}

// ─────────────────────────────────────────────────────────────
// 页面 3：局域网发现
// ─────────────────────────────────────────────────────────────

component PeersPage inherits VerticalLayout {
    in property <[LanPeer]> items;
    in property <bool> discovering;
    callback discover();
    callback connect-peer(string);

    spacing: 0px;
    padding: 24px;

    HorizontalLayout {
        height: 36px;
        Text {
            text: Tr.peers_title;
            color: Palette.text-bright;
            font-size: 20px;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }

        PBtn {
            text: root.discovering ? Tr.peers_scanning : Tr.peers_discover;
            enabled: !root.discovering;
            width: 100px;
            clicked => {
                root.discover();
            }
        }
    }

    Rectangle {
        height: 16px;
    }

    if items.length == 0: Rectangle {
        vertical-stretch: 1;
        VerticalLayout {
            alignment: center;
            spacing: 12px;
            Text {
                text: Tr.peers_no_peers;
                color: Palette.text-dim;
                font-size: 15px;
                horizontal-alignment: center;
            }

            Text {
                text: "";
                color: Palette.text-dim;
                font-size: 13px;
                horizontal-alignment: center;
            }
        }
    }

    if items.length > 0: ScrollView {
        vertical-stretch: 1;
        VerticalLayout {
            spacing: 10px;
            for item in root.items: Card {
                height: 80px;
                HorizontalLayout {
                    padding: 16px;
                    spacing: 14px;
                    alignment: start;
                    VerticalLayout {
                        alignment: center;
                        Dot {
                            online: item.online;
                        }
                    }

                    VerticalLayout {
                        horizontal-stretch: 1;
                        spacing: 4px;
                        alignment: center;
                        HorizontalLayout {
                            spacing: 10px;
                            Text {
                                text: item.id;
                                color: Palette.text-bright;
                                font-size: 16px;
                                font-weight: 700;
                            }

                            Text {
                                text: item.hostname;
                                color: Palette.text-dim;
                                font-size: 13px;
                                vertical-alignment: center;
                            }
                        }

                        HorizontalLayout {
                            spacing: 12px;
                            Label {
                                text: item.ip;
                            }

                            Label {
                                text: item.username;
                            }

                            Label {
                                text: item.platform;
                            }
                        }
                    }

                    PBtn {
                        text: Tr.peers_connect;
                        width: 70px;
                        clicked => {
                            root.connect-peer(item.id);
                        }
                    }
                }
            }
        }
    }
}

// ─────────────────────────────────────────────────────────────
// 页面 4：账户管理
// ─────────────────────────────────────────────────────────────

component AccountPage inherits VerticalLayout {
    in property <bool> logged-in;
    in property <string> username;
    in property <string> role;
    in property <string> token-remaining;
    in property <string> sub-plan;
    in property <int> sub-device-used;
    in property <int> sub-device-limit;
    in property <string> sub-expires;
    in property <bool> busy;
    in property <string> status-msg;
    in property <bool> status-ok;
    in-out property <string> input-user;
    in-out property <string> input-pass;
    in-out property <string> input-email;
    in-out property <string> input-device-name;
    in-out property <string> input-old-pass;
    in-out property <string> input-new-pass;
    in-out property <bool> show-register;

    callback do-login();
    callback do-logout();
    callback do-register();
    callback do-change-password();
    callback toggle-register();

    spacing: 0px;
    padding: 24px;

    Text {
        text: Tr.account_title;
        color: Palette.text-bright;
        font-size: 20px;
        font-weight: 700;
        height: 36px;
        vertical-alignment: center;
    }

    Rectangle {
        height: 16px;
    }

    // ── 已登录 ──────────────────────────────────────────────
    if logged-in: VerticalLayout {
        spacing: 14px;
        Card {
            height: 120px;
            HorizontalLayout {
                padding: 20px;
                spacing: 14px;
                alignment: start;
                // 头像圆
                Rectangle {
                    width: 54px;
                    height: 54px;
                    border-radius: 27px;
                    background: Palette.primary;
                    Text {
                        text: "U";
                        color: white;
                        font-size: 24px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                VerticalLayout {
                    alignment: center;
                    spacing: 6px;
                    Text {
                        text: root.username;
                        color: Palette.text-bright;
                        font-size: 18px;
                        font-weight: 700;
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle {
                            width: 44px;
                            height: 20px;
                            border-radius: 4px;
                            background: root.role == "admin" ? #e67700 : #1864ab;
                            Text {
                                text: root.role;
                                color: white;
                                font-size: 11px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        Label {
                            text: Tr.account_token_remaining + root.token-remaining;
                            vertical-alignment: center;
                        }
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                }

                GhostBtn {
                    text: Tr.btn_logout;
                    width: 82px;
                    danger: true;
                    clicked => {
                        root.do-logout();
                    }
                }
            }
        }

        // 订阅信息
        Card {
            VerticalLayout {
                padding: 20px;
                spacing: 12px;
                HorizontalLayout {
                    Text {
                        text: Tr.account_sub_plan;
                        color: Palette.text-bright;
                        font-size: 15px;
                        font-weight: 600;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                    }
                    Rectangle {
                        width: 80px;
                        height: 22px;
                        border-radius: 4px;
                        background: #1864ab22;
                        Text {
                            text: root.sub-plan;
                            color: #1864ab;
                            font-size: 12px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
                HorizontalLayout {
                    spacing: 24px;
                    VerticalLayout {
                        spacing: 3px;
                        Label {
                            text: Tr.account_sub_device_usage;
                            font-size: 11px;
                            color: Palette.text-dim;
                        }
                        Text {
                            text: root.sub-device-limit > 0
                                ? root.sub-device-used + " / " + root.sub-device-limit + " 台"
                                : root.sub-device-used + " 台（不限）";
                            color: Palette.text-bright;
                            font-size: 14px;
                            font-weight: 600;
                        }
                    }
                    VerticalLayout {
                        spacing: 3px;
                        Label {
                            text: Tr.account_sub_expires;
                            font-size: 11px;
                            color: Palette.text-dim;
                        }
                        Text {
                            text: root.sub-expires == "" ? Tr.account_sub_forever : root.sub-expires;
                            color: Palette.text-bright;
                            font-size: 14px;
                            font-weight: 600;
                        }
                    }
                }
            }
        }

        // 修改密码
        Card {
            VerticalLayout {
                padding: 20px;
                spacing: 12px;
                Text {
                    text: Tr.account_change_password;
                    color: Palette.text-bright;
                    font-size: 15px;
                    font-weight: 600;
                }

                Input {
                    placeholder: Tr.account_old_password;
                    password: true;
                    value <=> root.input-old-pass;
                }

                Input {
                    placeholder: Tr.account_new_password;
                    password: true;
                    value <=> root.input-new-pass;
                }

                HorizontalLayout {
                    spacing: 10px;
                    height: 36px;
                    Rectangle {
                        horizontal-stretch: 1;
                    }

                    PBtn {
                        text: root.busy ? Tr.status_processing : Tr.btn_change_password;
                        enabled: !root.busy;
                        width: 100px;
                        clicked => {
                            root.do-change-password();
                        }
                    }
                }

                if root.status-msg != "": StatusMsg {
                    msg: root.status-msg;
                    ok: root.status-ok;
                }
            }
        }
    }

    // ── 未登录：登录/注册表单 ───────────────────────────────
    if !logged-in: Card {
        VerticalLayout {
            padding: 24px;
            spacing: 14px;
            HorizontalLayout {
                Text {
                    text: root.show-register ? Tr.btn_register : Tr.btn_login;
                    color: Palette.text-bright;
                    font-size: 18px;
                    font-weight: 700;
                    horizontal-stretch: 1;
                }

                TouchArea {
                    width: 100px;
                    mouse-cursor: pointer;
                    clicked => {
                        root.toggle-register();
                    }
                    Text {
                        text: root.show-register ? Tr.account_login_link : Tr.account_register_link;
                        color: Palette.primary;
                        font-size: 13px;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                    }
                }
            }

            Input {
                placeholder: Tr.account_username;
                value <=> root.input-user;
            }

            if root.show-register: Input {
                placeholder: Tr.account_email;
                value <=> root.input-email;
            }
            Input {
                placeholder: Tr.account_password;
                password: true;
                value <=> root.input-pass;
            }

            if root.show-register: Input {
                placeholder: Tr.account_device_name;
                value <=> root.input-device-name;
            }
            if root.status-msg != "": StatusMsg {
                msg: root.status-msg;
                ok: root.status-ok;
            }
            PBtn {
                text: root.busy ? Tr.status_processing : (root.show-register ? Tr.btn_register : Tr.btn_login);
                enabled: !root.busy && root.input-user != "" && root.input-pass != "";
                height: 40px;
                clicked => {
                    if root.show-register {
                        root.do-register();
                    } else {
                        root.do-login();
                    }
                }
            }
        }
    }
    Rectangle {
        vertical-stretch: 1;
    }
}

// ─────────────────────────────────────────────────────────────
// 页面 5：设备管理
// ─────────────────────────────────────────────────────────────

component DevicesPage inherits VerticalLayout {
    in property <[BoundDevice]> items;
    in property <bool> logged-in;
    in property <bool> loading;
    callback refresh();
    callback remove-device(string);

    spacing: 0px;
    padding: 24px;

    HorizontalLayout {
        height: 36px;
        Text {
            text: Tr.devices_title;
            color: Palette.text-bright;
            font-size: 20px;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }

        GhostBtn {
            text: root.loading ? Tr.status_loading : Tr.btn_refresh;
            width: 72px;
            clicked => {
                root.refresh();
            }
        }
    }

    Rectangle {
        height: 16px;
    }

    if !logged-in: Rectangle {
        vertical-stretch: 1;
        Text {
            text: Tr.account_title;
            color: Palette.text-dim;
            font-size: 15px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    if logged-in && items.length == 0: Rectangle {
        vertical-stretch: 1;
        Text {
            text: Tr.devices_no_devices;
            color: Palette.text-dim;
            font-size: 15px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    if logged-in && items.length > 0: ScrollView {
        vertical-stretch: 1;
        VerticalLayout {
            spacing: 10px;
            for item in root.items: Card {
                height: 78px;
                HorizontalLayout {
                    padding: 16px;
                    spacing: 12px;
                    alignment: start;
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 10px;
                            height: 10px;
                            border-radius: 5px;
                            background: item.is-active ? Palette.success : Palette.text-dim;
                        }
                    }

                    VerticalLayout {
                        horizontal-stretch: 1;
                        spacing: 4px;
                        alignment: center;
                        Text {
                            text: item.device-name;
                            color: Palette.text-bright;
                            font-size: 15px;
                            font-weight: 600;
                        }

                        HorizontalLayout {
                            spacing: 16px;
                            Label {
                                text: "Peer ID: " + item.device-id;
                            }

                            Label {
                                text: "注册时间: " + item.created-at;
                            }
                        }
                    }

                    GhostBtn {
                        text: Tr.devices_remove;
                        width: 56px;
                        danger: true;
                        clicked => {
                            root.remove-device(item.device-id);
                        }
                    }
                }
            }
        }
    }
}

// ─────────────────────────────────────────────────────────────
// 页面 6：设置
// ─────────────────────────────────────────────────────────────

component SettingsPage inherits VerticalLayout {
    in-out property <string> server-addr;
    in-out property <string> api-url;
    in-out property <string> relay-server;
    in-out property <string> ipc-port-str;
    in property <string> status-msg;
    in property <bool> status-ok;
    in property <bool> busy;
    // 代理设置
    in-out property <bool> socks5-enabled;
    in-out property <string> socks5-exit-peer;
    in-out property <string> socks5-port-str: "1080";
    callback save();
    callback restart-mediator();
    callback open-config-file();
    callback set-language(string);
    callback toggle-socks5();
    callback save-proxy-settings();

    spacing: 0px;
    padding: 24px;

    Text {
        text: Tr.settings_title;
        color: Palette.text-bright;
        font-size: 20px;
        font-weight: 700;
        height: 36px;
        vertical-alignment: center;
    }

    Rectangle {
        height: 16px;
    }

    Card {
        VerticalLayout {
            padding: 20px;
            spacing: 14px;
            Text {
                text: Tr.settings_title;
                color: Palette.text-bright;
                font-size: 15px;
                font-weight: 600;
            }

            VerticalLayout {
                spacing: 6px;
                Label {
                    text: Tr.settings_server;
                }

                Input {
                    placeholder: "host:21116";
                    value <=> root.server-addr;
                }
            }

            VerticalLayout {
                spacing: 6px;
                Label {
                    text: Tr.settings_relay;
                }

                Input {
                    placeholder: "host:21117";
                    value <=> root.relay-server;
                }
            }

            VerticalLayout {
                spacing: 6px;
                Label {
                    text: "API";
                }

                Input {
                    placeholder: "http://host:8080";
                    value <=> root.api-url;
                }
            }

            VerticalLayout {
                spacing: 6px;
                Label {
                    text: "IPC";
                }

                Input {
                    placeholder: "21114";
                    value <=> root.ipc-port-str;
                }
            }

            // 语言选择
            HorizontalLayout {
                height: 36px;
                spacing: 10px;
                alignment: start;
                Label {
                    text: Tr.settings_language + ":";
                    vertical-alignment: center;
                    width: 90px;
                }

                PBtn {
                    text: Tr.lang_zh;
                    width: 72px;
                    clicked => {
                        root.set-language("zh");
                    }
                }

                PBtn {
                    text: Tr.lang_en;
                    width: 72px;
                    clicked => {
                        root.set-language("en");
                    }
                }
            }

            if root.status-msg != "": StatusMsg {
                msg: root.status-msg;
                ok: root.status-ok;
            }
            HorizontalLayout {
                spacing: 10px;
                height: 36px;
                PBtn {
                    text: root.busy ? Tr.status_processing : Tr.settings_save;
                    enabled: !root.busy;
                    width: 100px;
                    clicked => {
                        root.save();
                    }
                }

                GhostBtn {
                    text: Tr.settings_server;
                    width: 90px;
                    clicked => {
                        root.restart-mediator();
                    }
                }

                GhostBtn {
                    text: Tr.settings_open_config;
                    width: 110px;
                    clicked => {
                        root.open-config-file();
                    }
                }
            }
        }
    }

    Rectangle {
        height: 16px;
    }

    // 代理设置卡片
    Text {
        text: "代理设置";
        color: Palette.text-bright;
        font-size: 15px;
        font-weight: 600;
        height: 30px;
        vertical-alignment: center;
    }

    Card {
        VerticalLayout {
            padding: 16px;
            spacing: 10px;

            // SOCKS5 开关
            HorizontalLayout {
                height: 32px;
                Label {
                    text: "SOCKS5 代理";
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                PBtn {
                    text: root.socks5-enabled ? "已启用" : "已禁用";
                    small: true;
                    width: 72px;
                    clicked => {
                        root.toggle-socks5();
                    }
                }
            }

            // 出口节点
            HorizontalLayout {
                height: 32px;
                spacing: 8px;
                Label {
                    text: "出口 Peer ID";
                    vertical-alignment: center;
                    width: 90px;
                }

                Input {
                    placeholder: "对端 Peer ID";
                    value <=> root.socks5-exit-peer;
                    horizontal-stretch: 1;
                }
            }

            // 本地端口
            HorizontalLayout {
                height: 32px;
                spacing: 8px;
                Label {
                    text: "本地端口";
                    vertical-alignment: center;
                    width: 90px;
                }

                Input {
                    placeholder: "1080";
                    value <=> root.socks5-port-str;
                    horizontal-stretch: 1;
                }
            }

            // 保存按钮
            HorizontalLayout {
                height: 36px;
                Rectangle {
                    horizontal-stretch: 1;
                }

                PBtn {
                    text: "保存代理设置";
                    width: 120px;
                    clicked => {
                        root.save-proxy-settings();
                    }
                }
            }
        }
    }

    Rectangle {
        vertical-stretch: 1;
    }
}

// ─────────────────────────────────────────────────────────────
// 主窗口
// ─────────────────────────────────────────────────────────────

export component AppWindow inherits Window {
    title: "NAT Client";
    preferred-width: 960px;
    preferred-height: 640px;
    // 深色双色调渐变背景，让玻璃层有颜色互动感
    background: @linear-gradient(145deg, #070a13, #0a0714);

    // ── 状态属性 ──────────────────────────────────────────────
    in property <bool> online;
    in property <string> peer-id;
    in property <string> nat-type:   "未知";
    in property <string> server-addr;
    in property <bool> logged-in;
    in property <string> username;
    in property <string> role;
    in property <string> token-remaining;
    in property <string> sub-plan;
    in property <int> sub-device-used;
    in property <int> sub-device-limit;
    in property <string> sub-expires;
    in property <[ActiveConn]> connections;
    in property <[LanPeer]> lan-peers;
    in property <[BoundDevice]> devices;
    in property <bool> connecting;
    in property <bool> discovering;
    in property <bool> devices-loading;
    in property <bool> account-busy;
    in property <string> connect-result;
    in property <bool> connect-ok;
    in property <string> account-status;
    in property <bool> account-status-ok;
    in property <string> settings-status;
    in property <bool> settings-status-ok;

    // ── 设置字段（双向） ──────────────────────────────────────
    in-out property <string> cfg-server;
    in-out property <string> cfg-relay;
    in-out property <string> cfg-api-url;
    in-out property <string> cfg-ipc-port;

    // ── 代理设置字段（双向） ──────────────────────────────────
    in-out property <bool> socks5-enabled;
    in-out property <string> socks5-exit-peer;
    in-out property <string> socks5-port-str: "1080";

    // ── 输入字段（双向） ──────────────────────────────────────
    in-out property <string> quick-peer-id;
    in-out property <string> quick-local-port: "0";
    in-out property <string> login-user;
    in-out property <string> login-pass;
    in-out property <string> reg-email;
    in-out property <string> reg-device-name;
    in-out property <string> old-pass;
    in-out property <string> new-pass;
    in-out property <bool> show-register;

    // ── 导航 ──────────────────────────────────────────────────
    in-out property <int> page: 0;

    // ── 回调 ──────────────────────────────────────────────────
    callback do-connect(string, string);
    callback do-discover();
    callback do-refresh();
    callback close-conn(string);
    callback connect-peer(string);
    callback do-login();
    callback do-logout();
    callback do-register();
    callback do-change-password();
    callback do-remove-device(string);
    callback do-save-settings();
    callback do-restart-mediator();
    callback do-open-config();
    callback toggle-register();
    callback set-language(string);
    callback toggle-socks5();
    callback save-proxy-settings();

    // ── 布局 ──────────────────────────────────────────────────
    HorizontalLayout {

        // ── 侧边栏 ────────────────────────────────────────────
        Rectangle {
            width: 200px;
            // 比主背景更暗，形成深度层次
            background: @linear-gradient(180deg, #06080f, #05060c);

            VerticalLayout {
                padding: 12px;
                spacing: 4px;

                // Logo
                HorizontalLayout {
                    height: 60px;
                    padding-left: 12px;
                    spacing: 10px;
                    alignment: start;
                    // 玻璃 Logo 图标（渐变 + 光晕）
                    Rectangle {
                        width: 36px;
                        height: 36px;
                        border-radius: 10px;
                        background: @linear-gradient(135deg, #8ba3ff, #4c6ef5);
                        border-width: 1px;
                        border-color: #8ba3ff55;
                        drop-shadow-blur: 16px;
                        drop-shadow-color: #4c6ef560;
                        Text {
                            text: "N";
                            color: white;
                            font-size: 19px;
                            font-weight: 900;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        spacing: 2px;
                        Text {
                            text: "NAT Client";
                            color: Palette.text-bright;
                            font-size: 13px;
                            font-weight: 700;
                            letter-spacing: 0.5px;
                        }

                        Text {
                            text: "v0.1.0";
                            color: Palette.text-dim;
                            font-size: 10px;
                        }
                    }
                }

                Divider { }

                Rectangle {
                    height: 4px;
                }

                NavItem {
                    icon: "⊞";
                    label: Tr.nav_dashboard;
                    selected: page == 0;
                    clicked => {
                        root.page = 0;
                    }
                }

                NavItem {
                    icon: "⇄";
                    label: Tr.nav_connections;
                    selected: page == 1;
                    clicked => {
                        root.page = 1;
                    }
                }

                NavItem {
                    icon: "◉";
                    label: Tr.nav_peers;
                    selected: page == 2;
                    clicked => {
                        root.page = 2;
                    }
                }

                NavItem {
                    icon: "☺";
                    label: Tr.nav_account;
                    selected: page == 3;
                    clicked => {
                        root.page = 3;
                    }
                }

                NavItem {
                    icon: "▣";
                    label: Tr.nav_devices;
                    selected: page == 4;
                    clicked => {
                        root.page = 4;
                    }
                }

                NavItem {
                    icon: "⚙";
                    label: Tr.nav_settings;
                    selected: page == 5;
                    clicked => {
                        root.page = 5;
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                Divider { }

                // 底部状态
                HorizontalLayout {
                    height: 40px;
                    padding-left: 16px;
                    spacing: 8px;
                    alignment: start;
                    VerticalLayout {
                        alignment: center;
                        Dot {
                            online: root.online;
                        }
                    }

                    Text {
                        text: root.online ? Tr.status_online : Tr.status_offline;
                        color: root.online ? Palette.success : Palette.text-dim;
                        font-size: 12px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ── 侧边栏右侧玻璃分割线 ─────────────────────────────
        Rectangle {
            width: 1px;
            background: @linear-gradient(180deg, #ffffff00, #ffffff18, #ffffff18, #ffffff00);
        }

        // ── 内容区 ────────────────────────────────────────────
        Rectangle {
            horizontal-stretch: 1;
            background: transparent;

            if page == 0: DashboardPage {
                width: parent.width;
                height: parent.height;
                online <=> root.online;
                peer-id <=> root.peer-id;
                nat-type <=> root.nat-type;
                server-addr <=> root.server-addr;
                logged-in <=> root.logged-in;
                username <=> root.username;
                role <=> root.role;
                token-remaining <=> root.token-remaining;
                quick-peer-id <=> root.quick-peer-id;
                quick-local-port <=> root.quick-local-port;
                connecting <=> root.connecting;
                connect-result <=> root.connect-result;
                connect-ok <=> root.connect-ok;
                do-connect(id, port) => {
                    root.do-connect(id, port);
                }
                do-refresh => {
                    root.do-refresh();
                }
            }

            if page == 1: ConnectionsPage {
                width: parent.width;
                height: parent.height;
                items <=> root.connections;
                close-conn(u) => {
                    root.close-conn(u);
                }
            }

            if page == 2: PeersPage {
                width: parent.width;
                height: parent.height;
                items <=> root.lan-peers;
                discovering <=> root.discovering;
                discover => {
                    root.do-discover();
                }
                connect-peer(id) => {
                    root.connect-peer(id);
                }
            }

            if page == 3: AccountPage {
                width: parent.width;
                height: parent.height;
                logged-in <=> root.logged-in;
                username <=> root.username;
                role <=> root.role;
                token-remaining <=> root.token-remaining;
                sub-plan <=> root.sub-plan;
                sub-device-used <=> root.sub-device-used;
                sub-device-limit <=> root.sub-device-limit;
                sub-expires <=> root.sub-expires;
                busy <=> root.account-busy;
                status-msg <=> root.account-status;
                status-ok <=> root.account-status-ok;
                input-user <=> root.login-user;
                input-pass <=> root.login-pass;
                input-email <=> root.reg-email;
                input-device-name <=> root.reg-device-name;
                input-old-pass <=> root.old-pass;
                input-new-pass <=> root.new-pass;
                show-register <=> root.show-register;
                do-login => {
                    root.do-login();
                }
                do-logout => {
                    root.do-logout();
                }
                do-register => {
                    root.do-register();
                }
                do-change-password => {
                    root.do-change-password();
                }
                toggle-register => {
                    root.toggle-register();
                }
            }

            if page == 4: DevicesPage {
                width: parent.width;
                height: parent.height;
                items <=> root.devices;
                logged-in <=> root.logged-in;
                loading <=> root.devices-loading;
                refresh => {
                    root.do-refresh();
                }
                remove-device(id) => {
                    root.do-remove-device(id);
                }
            }

            if page == 5: SettingsPage {
                width: parent.width;
                height: parent.height;
                server-addr <=> root.cfg-server;
                relay-server <=> root.cfg-relay;
                api-url <=> root.cfg-api-url;
                ipc-port-str <=> root.cfg-ipc-port;
                status-msg <=> root.settings-status;
                status-ok <=> root.settings-status-ok;
                busy <=> root.account-busy;
                socks5-enabled <=> root.socks5-enabled;
                socks5-exit-peer <=> root.socks5-exit-peer;
                socks5-port-str <=> root.socks5-port-str;
                save => {
                    root.do-save-settings();
                }
                restart-mediator => {
                    root.do-restart-mediator();
                }
                open-config-file => {
                    root.do-open-config();
                }
                set-language(lang) => {
                    root.set-language(lang);
                }
                toggle-socks5 => {
                    root.toggle-socks5();
                }
                save-proxy-settings => {
                    root.save-proxy-settings();
                }
            }
        }
    }
}
