// ============================================================
//  NAT Client — 桌面 GUI (Slint 1.16)
//  深色主题，左侧导航，6 个功能页面
//  注意：Slint 字符串无 is-empty() / starts-with() / slice()
//        用 s == "" 代替 is-empty()，颜色通过独立 bool 属性控制
// ============================================================

import { Button, LineEdit, ScrollView, Spinner } from "std-widgets.slint";

// ─────────────────────────────────────────────────────────────
// 翻译 global（由 Rust 根据当前语言设置所有属性）
// ─────────────────────────────────────────────────────────────

